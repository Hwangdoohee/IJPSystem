<UserControl x:Class="IJPSystem.Platform.HMI.Views.InitializeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:domain="clr-namespace:IJPSystem.Platform.Domain.Enums;assembly=IJPSystem.Platform.Domain"
             mc:Ignorable="d" d:DesignHeight="780" d:DesignWidth="1200"
             Background="#0B0F1A">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측: 시퀀스 진행 ══════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 타이틀 + 상태 배지 -->
            <Border Grid.Row="0" Background="#111827" CornerRadius="12" Padding="16,12"
                    BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="INITIALIZE" Foreground="White"
                                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="서보 ON · 원점 복귀 · READY 위치 이동"
                                   Foreground="#64748B" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="8" Padding="14,8" VerticalAlignment="Center"
                            Background="{Binding StateColor}">
                        <TextBlock Text="{Binding StateText}" Foreground="White"
                                   FontWeight="Bold" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 스텝 테이블 -->
            <Border Grid.Row="1" Background="#111827" CornerRadius="12" Padding="4"
                    BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,10">
                <DataGrid ItemsSource="{Binding Steps}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserResizeRows="False"
                          Background="Transparent" Foreground="White"
                          BorderThickness="0" RowHeaderWidth="0"
                          HeadersVisibility="Column" RowHeight="34"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#1E293B"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0D1520"
                          SelectionMode="Single"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Running}">
                                    <Setter Property="Background" Value="#0F2B4A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Done}">
                                    <Setter Property="Background" Value="#061A0F"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Failed}">
                                    <Setter Property="Background" Value="#2D0808"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Aborted}">
                                    <Setter Property="Background" Value="#1A1000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Number}" Width="44">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="STEP NAME" Binding="{Binding Name}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="STATUS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                        <TextBlock Text="{Binding StatusIcon}" FontSize="11"
                                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#475569"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Running}">
                                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Done}">
                                                            <Setter Property="Foreground" Value="#22C55E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Failed}">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Aborted}">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="TIME" Binding="{Binding Elapsed}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 진행률 + 현재 단계 -->
            <Border Grid.Row="2" Background="#111827" CornerRadius="12" Padding="18,14"
                    BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="PROGRESS" Foreground="#64748B" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ProgressText}" Foreground="#94A3B8"
                                   FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Maximum="100"
                                 Height="8" Background="#1E293B" Foreground="#3B82F6" BorderThickness="0"/>
                    <TextBlock Text="{Binding CurrentStepName}" Foreground="White"
                               FontSize="13" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ 우측: 안내 + 제어 + 로그 ══════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 12축 모터 상태 / 포지션 (2열) -->
            <Border Grid.Row="0" Background="#111827" CornerRadius="12" Padding="12,10"
                    BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="AXIS STATUS" Foreground="#3B82F6"
                                   FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Axes.Count, StringFormat='{}{0} axes'}"
                                   Foreground="#64748B" FontSize="10" FontFamily="Consolas"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Axes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0B1322" CornerRadius="6" Padding="8,6" Margin="2"
                                        BorderBrush="#1E293B" BorderThickness="1">
                                    <StackPanel>
                                        <!-- 축 이름 + 번호 -->
                                        <Grid>
                                            <TextBlock Text="{Binding Info.Name}" Foreground="#E2E8F0"
                                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                                            <TextBlock Text="{Binding Info.AxisNo, StringFormat='#{0}'}"
                                                       Foreground="#64748B" FontSize="9" FontFamily="Consolas"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                        <!-- 상태 indicator (SVO / HOME / INP / ALM) -->
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Ellipse Width="6" Height="6" Margin="0,0,3,0" VerticalAlignment="Center"
                                                     Fill="{Binding IsServoOn, Converter={StaticResource BoolToSensorBrush}}"/>
                                            <TextBlock Text="SVO" Foreground="#94A3B8" FontSize="9"
                                                       FontFamily="Consolas" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <Ellipse Width="6" Height="6" Margin="0,0,3,0" VerticalAlignment="Center"
                                                     Fill="{Binding Status.IsHomeDone, Converter={StaticResource BoolToSensorBrush}}"/>
                                            <TextBlock Text="HOME" Foreground="#94A3B8" FontSize="9"
                                                       FontFamily="Consolas" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <Ellipse Width="6" Height="6" Margin="0,0,3,0" VerticalAlignment="Center"
                                                     Fill="{Binding Status.IsInPosition, Converter={StaticResource BoolToSensorBrush}}"/>
                                            <TextBlock Text="INP" Foreground="#94A3B8" FontSize="9"
                                                       FontFamily="Consolas" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <Ellipse Width="6" Height="6" Margin="0,0,3,0" VerticalAlignment="Center"
                                                     Fill="{Binding IsAlarm, Converter={StaticResource BoolToSensorBrush}, ConverterParameter=Alarm}"/>
                                            <TextBlock Text="ALM" Foreground="#94A3B8" FontSize="9"
                                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- 현재 위치 -->
                                        <TextBlock Text="{Binding CurrentPos, StringFormat='{}{0:F4} mm'}"
                                                   Foreground="#3B82F6" FontFamily="Consolas"
                                                   FontSize="13" FontWeight="Bold"
                                                   HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 제어 버튼 -->
            <Border Grid.Row="1" Background="#111827" CornerRadius="12" Padding="16"
                    BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Height="56"
                            Command="{Binding StartCommand}"
                            Style="{StaticResource MutedActionButtonStyle}"
                            Background="#1D4ED8">
                        <StackPanel>
                            <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="INIT" Foreground="White"
                                       FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Height="56"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource MutedActionButtonStyle}"
                            Background="#DC2626">
                        <StackPanel>
                            <TextBlock Text="■" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="STOP" Foreground="White"
                                       FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- 실행 로그 -->
            <Border Grid.Row="2" Background="#111827" CornerRadius="12" Padding="12"
                    BorderBrush="#334155" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="EXECUTION LOG"
                               Foreground="#3B82F6" FontWeight="Bold" FontSize="11" Margin="4,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ExecutionLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#94A3B8"
                                               FontSize="10" FontFamily="Consolas" Margin="2,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
