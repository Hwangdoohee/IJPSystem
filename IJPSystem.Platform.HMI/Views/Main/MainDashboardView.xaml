<UserControl x:Class="IJPSystem.Platform.HMI.Views.MainDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:domain="clr-namespace:IJPSystem.Platform.Domain.Enums;assembly=IJPSystem.Platform.Domain"
             mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1200"
             Background="#0F172A">

    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- 테스트용 알람 트리거 (구석에 작게 배치) -->
        <Button Grid.Column="0" Click="OpenAlarm_Click"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Width="28" Height="28" Margin="6,0,0,6"
                Background="Transparent" BorderThickness="0"
                ToolTip="테스트 알람 트리거 (개발용)" Cursor="Hand"
                Panel.ZIndex="99">
            <TextBlock Text="🚨" FontSize="14" Opacity="0.45"/>
        </Button>

        <Grid Grid.Column="0" Margin="0,0,25,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20,10,20,5">
                <TextBlock Text="MACHINE VISUALIZER" 
                           Style="{StaticResource SectionHeaderStyle}" 
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#1E293B" CornerRadius="15" BorderBrush="#334155" BorderThickness="1.5" Margin="10,10,10,10">
                <Grid>
                    <Viewbox Stretch="Fill" Margin="10">
                        <Canvas x:Name="MainCanvas" Width="800" Height="600" ClipToBounds="True">
                            <!--
                            ┌─────────────────────────────────────┐
                            │  GY1  ══════════════════════════════ │  y=52
                            │  [PRINT HEAD →→→→→→→→→→→→→→→→→→]  │
                            │  GY2  ══════════════════════════════ │  y=220
                            │                                       │
                            │  ░░░░░░░░ GLASS SUBSTRATE ░░░░░░░░  │  y=258
                            │  ○──○──○──○  X CONVEYOR  ○──○──○──○ │  y=462
                            └─────────────────────────────────────┘
                            -->

                            <!-- ── 배경 / 외곽 프레임 ─────────────────────────── -->
                            <Rectangle Width="800" Height="600" Fill="#060C18"/>
                            <Rectangle Canvas.Left="10" Canvas.Top="10" Width="780" Height="580"
                                       Fill="Transparent" Stroke="#1B2E4A" StrokeThickness="1.5" RadiusX="12" RadiusY="12"/>
                            <TextBlock Canvas.Left="22" Canvas.Top="19"
                                       Text="◈  INKJET SYSTEM  ·  MACHINE VISUALIZER"
                                       Foreground="#1B2E4A" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>

                            <!-- ── GY1 상단 수평 레일 ──────────────────────────── -->
                            <Rectangle Canvas.Left="40" Canvas.Top="52" Width="720" Height="18"
                                       Fill="#0B1929" Stroke="#2563EB" StrokeThickness="1.5" RadiusX="4" RadiusY="4"/>
                            <TextBlock Canvas.Left="46" Canvas.Top="56"
                                       Text="Rail1" Foreground="#2563EB"
                                       FontSize="9" FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Canvas.Left="700" Canvas.Top="56"
                                       Text="━━ Y RAIL (FRONT)" Foreground="#1B2E4A"
                                       FontSize="8" FontFamily="Consolas"/>

                            <!-- ── 좌우 수직 가이드 선 (점선) ─────────────────── -->
                            <Line X1="49"  Y1="70" X2="49"  Y2="238" Stroke="#1B2E4A" StrokeThickness="1" StrokeDashArray="5,4"/>
                            <Line X1="751" Y1="70" X2="751" Y2="238" Stroke="#1B2E4A" StrokeThickness="1" StrokeDashArray="5,4"/>

                            <!-- ── GY2 하단 수평 레일 ──────────────────────────── -->
                            <Rectangle Canvas.Left="40" Canvas.Top="220" Width="720" Height="18"
                                       Fill="#0B1929" Stroke="#2563EB" StrokeThickness="1.5" RadiusX="4" RadiusY="4"/>
                            <TextBlock Canvas.Left="46" Canvas.Top="224"
                                       Text="Rail2" Foreground="#2563EB"
                                       FontSize="9" FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Canvas.Left="700" Canvas.Top="224"
                                       Text="━━ Y RAIL (REAR)" Foreground="#1B2E4A"
                                       FontSize="8" FontFamily="Consolas"/>

                            <!-- ── 프린트 헤드 어셈블리 (좌→우 X 스캔) ─────────── -->
                            <Rectangle x:Name="PrintHeadBody"
                                       Canvas.Left="95" Canvas.Top="70"
                                       Width="70" Height="150"
                                       Fill="#6D28D9" Stroke="#A78BFA" StrokeThickness="1.5" RadiusX="5" RadiusY="5">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="HeadXTransform" X="-250"/>
                                </Rectangle.RenderTransform>
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#7C3AED" BlurRadius="14" ShadowDepth="0" Opacity="0.9"/>
                                </Rectangle.Effect>
                            </Rectangle>
                            <TextBlock Canvas.Left="102" Canvas.Top="135"
                                       Text="PRINT HEAD" Foreground="White"
                                       FontSize="8" FontFamily="Consolas" FontWeight="Bold">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="HeadLabelTransform" X="-250"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>

                            <!-- ── X 컨베이어 스테이지 ─────────────────────────── -->
                            <Rectangle Canvas.Left="40" Canvas.Top="462" Width="720" Height="7"
                                       Fill="#1B2E4A" RadiusX="3" RadiusY="3"/>
                            <Rectangle Canvas.Left="40" Canvas.Top="478" Width="720" Height="7"
                                       Fill="#1B2E4A" RadiusX="3" RadiusY="3"/>
                            <!-- 롤러 표시 -->
                            <Ellipse Canvas.Left="70"  Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="150" Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="230" Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="310" Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="390" Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="470" Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="550" Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="630" Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="710" Canvas.Top="458" Width="14" Height="14" Fill="#243146" Stroke="#334155" StrokeThickness="1.5"/>
                            <TextBlock Canvas.Left="320" Canvas.Top="493"
                                       Text="← ·  X — CONVEYOR  STAGE  · →"
                                       Foreground="#1B2E4A" FontSize="9" FontFamily="Consolas" FontWeight="Bold"/>

                            <!-- ── 유리 기판 그룹 (컨베이어 좌→우, GlassCanvas로 묶음) ── -->
                            <Canvas x:Name="GlassCanvas" Canvas.Left="0" Canvas.Top="0">
                                <Canvas.RenderTransform>
                                    <TranslateTransform x:Name="GlassTransform" X="-600"/>
                                </Canvas.RenderTransform>

                                <!-- 유리 기판 -->
                                <Rectangle x:Name="GlassRect"
                                           Canvas.Left="724" Canvas.Top="258"
                                           Width="540" Height="178"
                                           Fill="#040E1A" Stroke="#38BDF8" StrokeThickness="1.5" RadiusX="3" RadiusY="3" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <!-- 유리 내부 그리드 패턴 -->
                                <Path Canvas.Left="130" Canvas.Top="258"
                                      Stroke="#0E2A3D" StrokeThickness="1" Opacity="0.9">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <LineGeometry StartPoint="5,45"  EndPoint="535,45"/>
                                            <LineGeometry StartPoint="5,89"  EndPoint="535,89"/>
                                            <LineGeometry StartPoint="5,133" EndPoint="535,133"/>
                                            <LineGeometry StartPoint="67,5"  EndPoint="67,173"/>
                                            <LineGeometry StartPoint="134,5" EndPoint="134,173"/>
                                            <LineGeometry StartPoint="201,5" EndPoint="201,173"/>
                                            <LineGeometry StartPoint="268,5" EndPoint="268,173"/>
                                            <LineGeometry StartPoint="335,5" EndPoint="335,173"/>
                                            <LineGeometry StartPoint="402,5" EndPoint="402,173"/>
                                            <LineGeometry StartPoint="469,5" EndPoint="469,173"/>
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>

                                <!-- 유리 반사 하이라이트 -->
                                <Rectangle Canvas.Left="727" Canvas.Top="262" Width="532" Height="38"
                                           Opacity="0.07" RadiusX="2" RadiusY="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="White" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- 유리 라벨 -->
                                <TextBlock Canvas.Left="294" Canvas.Top="440"
                                           Text="GLASS SUBSTRATE (VC)" Foreground="#38BDF8"
                                           FontSize="9" FontFamily="Consolas" FontWeight="Bold"/>

                                <!-- 인쇄된 영역 (좌→우 ScaleX 확장) -->
                                <Rectangle x:Name="PrintedArea"
                                           Canvas.Left="132" Canvas.Top="260"
                                           Width="536" Height="174"
                                           Opacity="0.65" RadiusX="2" RadiusY="2"
                                           RenderTransformOrigin="0,0.5">
                                    <Rectangle.RenderTransform>
                                        <ScaleTransform x:Name="PrintedAreaScale" ScaleX="0" ScaleY="1"/>
                                    </Rectangle.RenderTransform>
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1D4ED8" Offset="0"/>
                                            <GradientStop Color="#6D28D9" Offset="0.5"/>
                                            <GradientStop Color="#4338CA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- 스캔 진행선 (좌→우 이동 수직선) -->
                                <Rectangle x:Name="ScanLine"
                                           Canvas.Left="132" Canvas.Top="260"
                                           Width="3" Height="174"
                                           Fill="#C4B5FD" Opacity="0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect Color="#7C3AED" BlurRadius="10" ShadowDepth="0" Opacity="1.0"/>
                                    </Rectangle.Effect>
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="ScanLineTransform" X="0"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Canvas>

                            <!-- ── 상태 배지 ──────────────────────────────────── -->
                            <Border Canvas.Left="100" Canvas.Top="516" Width="440" Height="28"
                                    Background="#0B1929" CornerRadius="6"
                                    BorderBrush="#1B2E4A" BorderThickness="1">
                                <TextBlock x:Name="StatusText"
                                           Text="● IDLE  —  READY TO START"
                                           Foreground="#475569" FontSize="10"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- X 위치 표시 -->
                            <Border Canvas.Left="568" Canvas.Top="516" Width="152" Height="28"
                                    Background="#0B1929" CornerRadius="6"
                                    BorderBrush="#1B2E4A" BorderThickness="1">
                                <TextBlock x:Name="YPosText"
                                           Text="GX :    0.000 mm"
                                           Foreground="#2563EB" FontSize="10"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1E293B" CornerRadius="12" Padding="14,8" Margin="0,0,10,0"  BorderBrush="#334155" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MOTOR POSITION (mm)" Foreground="#64748B" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 0 : X | Y -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,1,12,1">
                                <TextBlock Text="X :" Foreground="#94A3B8" FontFamily="Consolas" FontSize="13"/>
                                <TextBlock Text="{Binding MotorXPosition, StringFormat={}{0:F3}}" Foreground="#3B82F6" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Margin="6,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,1,0,1">
                                <TextBlock Text="Y :" Foreground="#94A3B8" FontFamily="Consolas" FontSize="13"/>
                                <TextBlock Text="{Binding MotorYPosition, StringFormat={}{0:F3}}" Foreground="#3B82F6" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Margin="6,0,0,0"/>
                            </StackPanel>

                            <!-- Row 1 : Z | Q -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,1,12,1">
                                <TextBlock Text="Z :" Foreground="#94A3B8" FontFamily="Consolas" FontSize="13"/>
                                <TextBlock Text="{Binding MotorZPosition, StringFormat={}{0:F3}}" Foreground="#3B82F6" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Margin="6,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,1,0,1">
                                <TextBlock Text="Q :" Foreground="#94A3B8" FontFamily="Consolas" FontSize="13"/>
                                <TextBlock Text="{Binding MotorQPosition, StringFormat={}{0:F3}}" Foreground="#3B82F6" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#1E293B" CornerRadius="12" Padding="14,8" BorderBrush="#334155" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- CYCLE TACT TIME (2/3) -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="CYCLE TACT TIME" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding TactTime, StringFormat={}{0:F2}}" Foreground="#3B82F6" FontSize="34" FontWeight="Black" VerticalAlignment="Center"/>
                                <TextBlock Text="SEC" Foreground="#475569" FontSize="13" FontWeight="Bold" VerticalAlignment="Bottom" Margin="6,0,0,8"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- TOTAL PRODUCTION (1/3) -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="TOTAL" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding TotalCount, StringFormat={}{0:N0}}" Foreground="White" FontSize="28" FontWeight="Black" VerticalAlignment="Center"/>
                                <TextBlock Text="PCS" Foreground="#475569" FontSize="11" FontWeight="Bold" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Grid>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="AUTO PRINT PROCESS" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ProcessProgress, StringFormat={}{0:F0}%}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="#3B82F6" FontWeight="ExtraBold" FontSize="14"
                               FontFamily="Consolas"/>
                </Grid>
                <ProgressBar Value="{Binding ProcessProgress}" Height="4"
                             Foreground="#3B82F6" Background="#1E293B" BorderThickness="0"
                             Margin="0,0,0,12"/>

                <Border Background="#111827" CornerRadius="12" Padding="14" Margin="0,0,0,12" BorderBrush="#1E293B" BorderThickness="2">
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,4" Margin="0,1" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Running}">
                                                    <Setter Property="Background" Value="#0F2B4A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Done}">
                                                    <Setter Property="Background" Value="#061A0F"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Failed}">
                                                    <Setter Property="Background" Value="#2D0808"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Aborted}">
                                                    <Setter Property="Background" Value="#1A1000"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Number}" Foreground="#64748B" FontFamily="Consolas" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Running}">
                                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Done}">
                                                            <Setter Property="Foreground" Value="#22C55E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Failed}">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Aborted}">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="3" Text="{Binding Elapsed}" Foreground="#64748B" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="▶ START" Command="{Binding StartCommand}"
                            Style="{StaticResource MainDashboardButtonStyle}" Background="#059669"
                            Height="50" FontSize="18" Margin="0,0,8,0"/>

                    <Button Grid.Column="1" Content="■ STOP" Command="{Binding StopCommand}"
                            Style="{StaticResource MainDashboardButtonStyle}" Background="#DC2626"
                            Height="50" FontSize="18" Margin="8,0,0,0"/>
                </Grid>

                <!-- ── RECENT CYCLES ── -->
                <Border Background="#0B1220" CornerRadius="10" Padding="12,10" Margin="0,15,0,0"
                        BorderBrush="#1E293B" BorderThickness="1">
                    <StackPanel>
                        <!-- 헤더: 타이틀 + AVG/MIN/MAX 통계 -->
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="RECENT CYCLES" Foreground="#3B82F6"
                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="AVG " Foreground="#64748B" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AverageTact, StringFormat={}{0:F2}s}" Foreground="#3B82F6" FontFamily="Consolas" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="MIN " Foreground="#64748B" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding MinTact, StringFormat={}{0:F2}s}" Foreground="#22C55E" FontFamily="Consolas" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="MAX " Foreground="#64748B" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding MaxTact, StringFormat={}{0:F2}s}" Foreground="#F59E0B" FontFamily="Consolas" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- 빈 상태 안내 -->
                        <TextBlock Text="아직 완료된 사이클이 없습니다." Foreground="#334155"
                                   FontSize="10" FontStyle="Italic" HorizontalAlignment="Center"
                                   Margin="0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentCycles.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 사이클 막대 차트 (각 행: #번호  바  타임) -->
                        <ItemsControl ItemsSource="{Binding RecentCycles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Foreground="#64748B" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding TactTime, Mode=OneWay}"
                                                     Maximum="{Binding DataContext.MaxTact, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                     Foreground="#3B82F6" Background="#1E293B"
                                                     Height="10" BorderThickness="0"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TimeText}"
                                                   Foreground="#94A3B8" FontFamily="Consolas"
                                                   FontSize="10" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Button Content="⚠️ EMERGENCY RESET" Command="{Binding ResetCommand}"
                        Background="#EF4444" Margin="0,15,0,0" Height="50" FontWeight="Bold">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MainDashboardButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>