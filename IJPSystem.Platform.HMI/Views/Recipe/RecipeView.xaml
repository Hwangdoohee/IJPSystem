<UserControl x:Class="IJPSystem.Platform.HMI.Views.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1200"
             Background="#0F172A">
    <UserControl.Resources>
        <!-- ── 이 파일에서만 쓰는 스타일 ── -->
        <Style x:Key="RecipeColumnHeaderStyle" TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource CommonColumnHeaderStyle}">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height"   Value="45"/>
        </Style>
        <Style x:Key="RecipeCompareCellStyle" TargetType="DataGridCell"
               BasedOn="{StaticResource CompareCellStyle}">
            <Setter Property="FontSize"                   Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>
        <Style x:Key="NumericEditingStyle" TargetType="TextBox">
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="15"/>
            <EventSetter Event="PreviewTextInput" Handler="TextBox_PreviewTextInput"/>
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown"/>
            <EventSetter Event="GotFocus" Handler="TextBox_GotFocus"/>
            <Style.Triggers>
                <!-- 미사용 축(AxisUsed=false → IsEnabled=false) 표시: 어두운 적갈색 + 흐린 텍스트
                     기본 WPF disabled 회색보다 명확히 "사용 안함"임을 인식할 수 있게 한다 -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background"  Value="#3F1D1D"/>
                    <Setter Property="BorderBrush" Value="#7F1D1D"/>
                    <Setter Property="Foreground"  Value="#FCA5A5"/>
                    <Setter Property="Opacity"     Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NumericDisplayStyle" TargetType="TextBlock">
            <Setter Property="FontSize"             Value="15"/>
            <Setter Property="HorizontalAlignment"  Value="Center"/>
            <Setter Property="VerticalAlignment"    Value="Center"/>
            <Setter Property="TextAlignment"        Value="Center"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E293B" CornerRadius="12" Margin="0,0,20,0" BorderBrush="#334155" BorderThickness="1">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="5,0,0,15">
                    <TextBlock Text="📋" Foreground="#3B82F6" Margin="0,0,8,0" FontSize="16"/>
                    <TextBlock Text="RECIPE MODELS" Foreground="White" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <ListBox Grid.Row="1" ItemsSource="{Binding RecipeNames}" 
                         SelectedItem="{Binding SelectedRecipeName}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" d:ItemsSource="{d:SampleData ItemCount=5}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" Background="#111827" CornerRadius="6" Padding="12,10">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A2233"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#1D4ED8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <UniformGrid Grid.Row="2" Rows="3" Columns="2" Margin="0,15,0,0">
                    <Button Content="ADD"
                            FontSize="12" Padding="0" Width="110"
                            Command="{Binding CreateRecipeCommand}"
                            Style="{StaticResource MainDashboardButtonStyle}"
                            Height="38" Margin="0,0,2,2" Background="#059669"/>

                    <Button Content="COPY"
                            FontSize="12" Padding="0" Width="110"
                            Command="{Binding CopyRecipeCommand}"
                            Style="{StaticResource MainDashboardButtonStyle}"
                            Height="38" Margin="2,0,0,2" Background="#334155"/>

                    <Button Content="EDIT"
                            FontSize="12" Padding="0" Width="110"
                            Command="{Binding RenameRecipeCommand}"
                            Style="{StaticResource MainDashboardButtonStyle}"
                            Height="38" Margin="0,2,2,2" Background="#334155"/>

                    <Button Content="DEL"
                            FontSize="12" Padding="0" Width="110"
                            Command="{Binding DeleteRecipeCommand}"
                            Style="{StaticResource MainDashboardButtonStyle}"
                            Height="38" Margin="2,2,0,2" Background="#DC2626"/>

                    <Button Content="▲  UP"
                            FontSize="12" Padding="0" Width="110"
                            Command="{Binding MoveRecipeUpCommand}"
                            Style="{StaticResource MainDashboardButtonStyle}"
                            Height="38" Margin="0,2,2,0" Background="#334155"/>

                    <Button Content="▼  DOWN"
                            FontSize="12" Padding="0" Width="110"
                            Command="{Binding MoveRecipeDownCommand}"
                            Style="{StaticResource MainDashboardButtonStyle}"
                            Height="38" Margin="2,2,0,0" Background="#334155"/>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        
            <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="15,10" Margin="0,0,0,15" BorderBrush="#334155" BorderThickness="1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#064E3B" Padding="10,5" CornerRadius="6" Margin="0,0,25,0" BorderBrush="#22C55E" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="● RUNNING :" Foreground="#22C55E" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ActiveRecipeName}" Foreground="White" FontSize="15" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="EDITING :" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedRecipeName}" Foreground="#FCD34D" FontSize="20" FontWeight="Black" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="*" Foreground="#F59E0B" FontSize="24" FontWeight="Bold" Margin="5,-5,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="⚙️" Foreground="#3B82F6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AxisList.Count, StringFormat='Axes: {0}'}" Foreground="White" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <!-- ── 모터 파라미터 ─────────────────────────────────────── -->
                <Border Background="#111827" CornerRadius="8"
                        BorderBrush="#334155" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentDataType}" Value="Teach">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentDataType}" Value="Other">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DataGrid ItemsSource="{Binding AxisList}"
                              AutoGenerateColumns="False"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="False"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Standard"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0" BorderBrush="Transparent"
                              RowHeaderWidth="0" HeadersVisibility="Column"
                              RowHeight="42" ColumnHeaderHeight="42"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2D3748"
                              RowBackground="#111827"
                              AlternatingRowBackground="#1A2233"
                              SelectionMode="Single"
                              ColumnHeaderStyle="{StaticResource RecipeColumnHeaderStyle}"
                              HorizontalScrollBarVisibility="Visible"
                              VerticalScrollBarVisibility="Auto"
                              GotFocus="DataGrid_GotFocus"
                              CellEditEnding="DataGrid_CellEditEnding">
                        <DataGrid.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="AXIS"
                                                Binding="{Binding Info.AxisNo}"
                                                IsReadOnly="True" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize"            Value="14"/>
                                        <Setter Property="FontWeight"          Value="Bold"/>
                                        <Setter Property="Foreground"          Value="#93C5FD"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment"   Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Move VEL"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Move.Velocity,          UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                            <DataGridTextColumn Header="Move ACC"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Move.Acceleration,      UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                            <DataGridTextColumn Header="Move DEC"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Move.Deceleration,      UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                            <DataGridTextColumn Header="JOG VEL"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Jog.Velocity,           UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                            <DataGridTextColumn Header="JOG ACC"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Jog.Acceleration,       UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                            <DataGridTextColumn Header="JOG DEC"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Jog.Deceleration,       UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                            <DataGridTextColumn Header="PRINT VEL"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Printing.Velocity,      UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                            <DataGridTextColumn Header="PRINT ACC"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Printing.Acceleration,  UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                            <DataGridTextColumn Header="PRINT DEC"
                                                ElementStyle="{StaticResource NumericDisplayStyle}"
                                                EditingElementStyle="{StaticResource NumericEditingStyle}"
                                                Binding="{Binding Info.MotionConfig.Printing.Deceleration,  UpdateSourceTrigger=LostFocus}"
                                                CellStyle="{StaticResource RecipeCompareCellStyle}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- ── Purge 시간 설정 (OTHER INFO) ──────────────────────── -->
                <Border Background="#111827" CornerRadius="8"
                        BorderBrush="#334155" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentDataType}" Value="Other">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>   <!-- 왼쪽 1/4 카드 -->
                            <ColumnDefinition Width="3*"/>  <!-- 나머지 빈 공간 -->
                        </Grid.ColumnDefinitions>

                        <!-- ── Purge Time 카드 (왼쪽 1/4) ── -->
                        <Border Grid.Column="0" Background="#1E293B" CornerRadius="10"
                                BorderBrush="#334155" BorderThickness="1"
                                Margin="20" Padding="16">
                            <StackPanel VerticalAlignment="Center">

                                <!-- 타이틀 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="⏱" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="PURGE TIME" Foreground="White"
                                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- 현재 값 표시 -->
                                <Border Background="#0F172A" CornerRadius="8"
                                        BorderBrush="#3B82F6" BorderThickness="2"
                                        Padding="0,14" Margin="0,0,0,16" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding PurgeTime}"
                                                   Foreground="#60A5FA" FontSize="44" FontWeight="Black"
                                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                                        <TextBlock Text=" sec" Foreground="#64748B"
                                                   FontSize="18" FontWeight="Bold"
                                                   VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                                    </StackPanel>
                                </Border>

                                <!-- 슬라이더 -->
                                <Slider Minimum="0" Maximum="60"
                                        IsSnapToTickEnabled="False"
                                        Value="{Binding PurgeTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="4,0,4,4" Height="26">
                                    <Slider.Style>
                                        <Style TargetType="Slider">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Slider">
                                                        <Grid>
                                                            <Border Height="6" CornerRadius="3"
                                                                    Background="#0F172A" BorderBrush="#334155" BorderThickness="1"
                                                                    VerticalAlignment="Center"/>
                                                            <Track x:Name="PART_Track">
                                                                <Track.DecreaseRepeatButton>
                                                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                                                                </Track.DecreaseRepeatButton>
                                                                <Track.Thumb>
                                                                    <Thumb Cursor="Hand">
                                                                        <Thumb.Template>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Ellipse Fill="#3B82F6" Stroke="#93C5FD" StrokeThickness="2"
                                                                                         Width="20" Height="20">
                                                                                    <Ellipse.Effect>
                                                                                        <DropShadowEffect Color="#3B82F6" BlurRadius="8" ShadowDepth="0"/>
                                                                                    </Ellipse.Effect>
                                                                                </Ellipse>
                                                                            </ControlTemplate>
                                                                        </Thumb.Template>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                                <Track.IncreaseRepeatButton>
                                                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                                                                </Track.IncreaseRepeatButton>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Slider.Style>
                                </Slider>

                                <!-- 눈금 레이블 -->
                                <Grid Margin="4,0,4,16">
                                    <TextBlock Text="0" Foreground="#475569" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Left"/>
                                    <TextBlock Text="30" Foreground="#475569" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Center"/>
                                    <TextBlock Text="60" Foreground="#475569" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- 직접 입력 -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="직접 입력" Foreground="#64748B" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Border BorderBrush="#475569" BorderThickness="1" CornerRadius="6"
                                            Background="#0F172A" Width="60">
                                        <TextBox Text="{Binding PurgeTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Foreground="White" Background="Transparent"
                                                 BorderThickness="0" FontSize="15" FontFamily="Consolas"
                                                 TextAlignment="Center" VerticalContentAlignment="Center"
                                                 Padding="0,5"
                                                 Style="{StaticResource NumericEditingStyle}"/>
                                    </Border>
                                    <TextBlock Text=" sec" Foreground="#64748B" FontSize="12"
                                               VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── 티칭 포인트 ──────────────────────────────────────── -->
                <Border Background="#111827" CornerRadius="8"
                        BorderBrush="#334155" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentDataType}" Value="Teach">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DataGrid x:Name="TeachingPointGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="False"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Standard"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0" BorderBrush="Transparent"
                              RowHeaderWidth="0" HeadersVisibility="Column"
                              RowHeight="42" ColumnHeaderHeight="42"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2D3748"
                              RowBackground="#111827"
                              AlternatingRowBackground="#1A2233"
                              SelectionMode="Single"
                              ColumnHeaderStyle="{StaticResource RecipeColumnHeaderStyle}"
                              HorizontalScrollBarVisibility="Visible"
                              VerticalScrollBarVisibility="Auto"
                              GotFocus="TeachingGrid_GotFocus"
                              CellEditEnding="TeachingGrid_CellEditEnding">
                        <DataGrid.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}"/>
                        </DataGrid.Resources>
                    </DataGrid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#1E293B" CornerRadius="8" 
                    Padding="15" Margin="0,15,0,0" 
                    BorderBrush="#334155" BorderThickness="1">
                <Grid>
                    <TextBlock Text="{DynamicResource Recipe_SaveApplyHint}"
                            Foreground="#64748B" FontSize="10"
                            VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- CANCEL 버튼 (IsDirty일 때만 표시) -->
                        <Button Command="{Binding CancelEditCommand}"
                                Style="{StaticResource MainDashboardButtonStyle}"
                                Width="150" Height="45" Margin="0,0,10,0"
                                Background="#7F1D1D" BorderBrush="#EF4444"
                                Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✕" FontSize="14" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="CANCEL EDIT" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- DIFF 버튼 — 활성/선택 레시피 비교 (또는 임의 두 레시피) -->
                        <Button Command="{Binding OpenDiffCommand}"
                                Style="{StaticResource MainDashboardButtonStyle}"
                                Width="160" Height="45" Background="#7C3AED" Margin="0,0,10,0"
                                ToolTip="두 레시피의 모든 파라미터/티칭 좌표 차이를 비교">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⇄" FontSize="14" Margin="0,0,6,0"
                                            VerticalAlignment="Center"/>
                                <TextBlock Text="DIFF MODELS" FontWeight="Bold"
                                            VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- SAVE 버튼 -->
                        <Button Command="{Binding SaveRecipeCommand}"
                                Style="{StaticResource RecipeSaveButtonStyle}"
                                Width="180" Height="45" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" FontSize="14" Margin="0,0,6,0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="SAVE MODEL" FontWeight="Bold"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                        </Button>
                        <!-- APPLY 버튼 -->
                        <Button Command="{Binding ApplyRecipeCommand}"
                                Style="{StaticResource MainDashboardButtonStyle}"
                                Width="220" Height="45" Background="#1D4ED8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚀" FontSize="14" Margin="0,0,6,0"
                                            VerticalAlignment="Center"/>
                                <TextBlock Text="APPLY TO MACHINE" FontWeight="Bold"
                                            VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>