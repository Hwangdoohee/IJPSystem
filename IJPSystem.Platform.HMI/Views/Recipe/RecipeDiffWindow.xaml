<Window x:Class="IJPSystem.Platform.HMI.Views.RecipeDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IJPSystem.Platform.HMI.Views"
        mc:Ignorable="d"
        Title="Recipe Diff Viewer"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 헤더 ──────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#A78BFA" Width="4" Height="24" CornerRadius="2" Margin="0,0,15,0"/>
                <TextBlock Text="RECIPE DIFF VIEWER" Foreground="White"
                           FontSize="22" FontWeight="ExtraBold" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Differences:" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding DifferenceCount}"
                           Foreground="#F97316" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="/" Foreground="#64748B" Margin="6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalCount}"
                           Foreground="#94A3B8" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ── 선택 바 ───────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#1E293B" CornerRadius="10" Padding="14,10"
                BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="LEFT" Foreground="#94A3B8" FontSize="12" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding RecipeNames}"
                          SelectedItem="{Binding LeftRecipe, Mode=TwoWay}"
                          Width="220" Height="32" FontSize="13" FontWeight="Bold"
                          Background="#0F172A" Foreground="Black"
                          BorderBrush="#475569" VerticalContentAlignment="Center"/>

                <Button Content="⇄ SWAP" Command="{Binding SwapCommand}"
                        Width="90" Height="32" Margin="12,0"
                        Style="{StaticResource ModernActionButton}"
                        Background="#334155" BorderBrush="#475569"/>

                <TextBlock Text="RIGHT" Foreground="#94A3B8" FontSize="12" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding RecipeNames}"
                          SelectedItem="{Binding RightRecipe, Mode=TwoWay}"
                          Width="220" Height="32" FontSize="13" FontWeight="Bold"
                          Background="#0F172A" Foreground="Black"
                          BorderBrush="#475569" VerticalContentAlignment="Center"/>

                <CheckBox Content="Show only differences"
                          IsChecked="{Binding ShowOnlyDifferences, Mode=TwoWay}"
                          Foreground="#CBD5E1" FontSize="12" Margin="20,0,0,0"
                          VerticalAlignment="Center"/>

                <Button Content="REFRESH" Command="{Binding RefreshCommand}"
                        Width="90" Height="32" Margin="20,0,0,0"
                        Style="{StaticResource ModernActionButton}"
                        Background="#0F766E" BorderBrush="#14B8A6"/>
            </StackPanel>
        </Border>

        <!-- ── DataGrid ──────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#1E293B" CornerRadius="12" Padding="5"
                BorderBrush="#334155" BorderThickness="1">
            <DataGrid x:Name="DiffGrid"
                      ItemsSource="{Binding FilteredEntries}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#334155"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeight="32"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ColumnHeaderStyle="{StaticResource CommonColumnHeaderStyle}"
                      CellStyle="{StaticResource CommonCellStyle}">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDifferent}" Value="True">
                                <Setter Property="Background" Value="#3D2D0F"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="CATEGORY"
                            Binding="{Binding Category}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="PARAMETER"
                            Binding="{Binding Parameter}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="LEFT"
                            Binding="{Binding LeftValue}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferent}" Value="True">
                                        <Setter Property="Foreground" Value="#FBBF24"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="RIGHT"
                            Binding="{Binding RightValue}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferent}" Value="True">
                                        <Setter Property="Foreground" Value="#FBBF24"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── 하단 ──────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <TextBlock Text="● Highlighted rows = different"
                       Foreground="#F97316" FontSize="11"
                       VerticalAlignment="Center" HorizontalAlignment="Left"/>
            <Button Content="CLOSE" Click="Close_Click"
                    Width="100" Height="36" HorizontalAlignment="Right"
                    Style="{StaticResource ModernActionButton}"
                    Background="#334155" BorderBrush="#475569"/>
        </Grid>
    </Grid>
</Window>
