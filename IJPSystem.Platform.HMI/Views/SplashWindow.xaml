<Window x:Class="IJPSystem.Platform.HMI.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight">

    <!-- 둥근 카드 — 그림자 효과 -->
    <Border Background="#0F172A" CornerRadius="12"
            BorderBrush="#334155" BorderThickness="1"
            Padding="42,32" Margin="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.6" ShadowDepth="0"/>
        </Border.Effect>

        <StackPanel MinWidth="540">
            <!-- 로고 + 타이틀 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                <Border Background="White" Width="58" Height="58" CornerRadius="10" Padding="6">
                    <Image Source="/Images/logo.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="GOSAN TECH" Foreground="#3B82F6" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding MachineName}" Foreground="White" FontSize="22" FontWeight="ExtraBold"/>
                    <TextBlock Text="System Initializing..." Foreground="#94A3B8" FontSize="11" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- 단계별 진행 -->
            <Border Background="#1E293B" CornerRadius="8" Padding="22,16"
                    BorderBrush="#334155" BorderThickness="1">
                <ItemsControl ItemsSource="{Binding InitSteps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                           Foreground="{Binding IconColor}"
                                           FontSize="15" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="#94A3B8" FontSize="10" Margin="0,1,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding ErrorMessage}"
                                           Foreground="#EF4444" FontSize="10"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <TextBlock Text="v1.0  |  Inkjet Production HMI"
                       Foreground="#475569" FontSize="9"
                       HorizontalAlignment="Center" Margin="0,18,0,0"/>
        </StackPanel>
    </Border>
</Window>
