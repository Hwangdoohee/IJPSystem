<UserControl x:Class="IJPSystem.Platform.HMI.Views.SequenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:domain="clr-namespace:IJPSystem.Platform.Domain.Enums;assembly=IJPSystem.Platform.Domain"
             mc:Ignorable="d" d:DesignHeight="780" d:DesignWidth="1200"
             Background="#0B0F1A">

    <UserControl.Resources>
        <Style x:Key="SequenceColumnHeaderStyle" TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource RecipeColumnHeaderStyle}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height"   Value="34"/>
            <Setter Property="Padding"  Value="10,0"/>
        </Style>
    </UserControl.Resources>
 
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측: 시퀀스 목록 (ListBox) ═══════════════════════════════ -->
        <Border Grid.Column="0" Background="#111827" CornerRadius="12" Padding="12"
                BorderBrush="#334155" BorderThickness="1" Margin="0,0,12,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="SEQUENCE LIST"
                           Foreground="#3B82F6" FontWeight="Bold" FontSize="12"
                           Margin="4,0,0,14"/>

                <ListBox ItemsSource="{Binding Sequences}"
                         SelectedItem="{Binding SelectedSequence}"
                         Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,5"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="CardBorder" CornerRadius="8" Padding="10,8"
                                                Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="#1E3A5F"/>
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#3B82F6"/>
                                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#60A5FA"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{Binding Icon}" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               FontWeight="Bold" FontSize="11" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" Foreground="#64748B"
                                           FontSize="9" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ══ 우측: 실행 패널 ═══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 시퀀스명 + 상태 배지 -->
            <Border Grid.Row="0" Background="#111827" CornerRadius="12" Padding="14,10"
                    BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="SELECTED SEQUENCE" Foreground="#64748B"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SelectedSequence.Icon}" FontSize="13"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedSequence.Name}" Foreground="White"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedSequence.Description}"
                                   Foreground="#64748B" FontSize="10" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- 상태 배지: DataTrigger로 색상 전환 -->
                    <Border Grid.Column="1" CornerRadius="8" Padding="14,8" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#334155"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding State}" Value="{x:Static domain:SequenceState.Running}">
                                        <Setter Property="Background" Value="#1D4ED8"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="{x:Static domain:SequenceState.Paused}">
                                        <Setter Property="Background" Value="#92400E"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="{x:Static domain:SequenceState.Completed}">
                                        <Setter Property="Background" Value="#166534"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="{x:Static domain:SequenceState.Aborted}">
                                        <Setter Property="Background" Value="#7C2D12"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="{x:Static domain:SequenceState.Error}">
                                        <Setter Property="Background" Value="#7F1D1D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StateText}" Foreground="White"
                                   FontWeight="Bold" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 스텝 테이블 -->
            <Border Grid.Row="1" Background="#111827" CornerRadius="12" Padding="4"
                    BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,10">
                <DataGrid ItemsSource="{Binding ActiveSteps}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserResizeRows="False"
                          Background="Transparent" Foreground="White"
                          BorderThickness="0" RowHeaderWidth="0"
                          HeadersVisibility="Column"
                          RowHeight="36"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#1E293B"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0D1520"
                          SelectionMode="Single"
                          ColumnHeaderStyle="{StaticResource SequenceColumnHeaderStyle}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">

                    <DataGrid.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}"/>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Running}">
                                    <Setter Property="Background" Value="#0F2B4A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Done}">
                                    <Setter Property="Background" Value="#061A0F"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Failed}">
                                    <Setter Property="Background" Value="#2D0808"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Aborted}">
                                    <Setter Property="Background" Value="#1A1000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Number}" Width="44">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="STEP NAME" Binding="{Binding Name}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="STATUS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                        <TextBlock Text="{Binding StatusIcon}" FontSize="11"
                                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#475569"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Running}">
                                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Done}">
                                                            <Setter Property="Foreground" Value="#22C55E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Failed}">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:StepStatus.Aborted}">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="TIME" Binding="{Binding Elapsed}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 진행률 -->
            <Border Grid.Row="2" Background="#111827" CornerRadius="12" Padding="18,14"
                    BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="PROGRESS" Foreground="#64748B" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ProgressText}" Foreground="#94A3B8"
                                   FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Height="16" CornerRadius="8" Background="#1E293B" x:Name="ProgressTrack">
                        <Border HorizontalAlignment="Left" CornerRadius="8" Height="16" MinWidth="0">
                            <Border.Width>
                                <MultiBinding>
                                    <MultiBinding.Converter>
                                        <local:ProgressToWidthConverter xmlns:local="clr-namespace:IJPSystem.Platform.HMI.Common.Converters"/>
                                    </MultiBinding.Converter>
                                    <Binding Path="Progress"/>
                                    <Binding Path="ActualWidth" ElementName="ProgressTrack"/>
                                </MultiBinding>
                            </Border.Width>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#3B82F6"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State}" Value="{x:Static domain:SequenceState.Completed}">
                                            <Setter Property="Background" Value="#22C55E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="{x:Static domain:SequenceState.Aborted}">
                                            <Setter Property="Background" Value="#F59E0B"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="{x:Static domain:SequenceState.Error}">
                                            <Setter Property="Background" Value="#EF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 제어 버튼 -->
            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Height="62" Command="{Binding StartCommand}"
                        Style="{StaticResource MutedActionButtonStyle}" Background="#166534">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" FontSize="18" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="START" FontSize="18" FontWeight="Black" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Height="62" Command="{Binding PauseResumeCommand}"
                        Style="{StaticResource MutedActionButtonStyle}" Background="#92400E">
                    <TextBlock Text="{Binding PauseResumeLabel}" FontSize="16"
                               FontWeight="Black" Foreground="White"/>
                </Button>

                <Button Grid.Column="4" Height="62" Command="{Binding AbortCommand}"
                        Style="{StaticResource MutedActionButtonStyle}" Background="#7F1D1D">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏹" FontSize="18" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ABORT" FontSize="18" FontWeight="Black" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 실행 로그 -->
            <Border Grid.Row="4" Background="#0D1117" CornerRadius="12" Padding="14,10"
                    BorderBrush="#334155" BorderThickness="1" MaxHeight="155">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="EXECUTION LOG"
                               Foreground="#3B82F6" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ExecutionLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#94A3B8"
                                               FontFamily="Consolas" FontSize="11" Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
