                    </Border>

                    <!-- Action Buttons -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,12">
                        <StackPanel>

                            <!-- 자동 시퀀스 (Auto 퍼지 / Auto Blotting) -->
                            <TextBlock Text="AUTO SEQUENCE" Foreground="#3B82F6"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Button Height="58" Margin="0,0,0,6"
                                    Style="{StaticResource MutedActionButtonStyle}" Background="#166534"
                                    Command="{Binding AutoPurgeCommand}"
                                    ToolTip="자동 퍼지 시퀀스 시작">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶" FontSize="18" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="자동 퍼지"  FontSize="14" FontWeight="Black" Foreground="White"/>
                                        <TextBlock Text="AUTO PURGE" FontSize="9"  Foreground="#86EFAC"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                            <Button Height="58" Margin="0,0,0,6"
                                    Style="{StaticResource MutedActionButtonStyle}" Background="#0E7490"
                                    Command="{Binding AutoBlottingCommand}"
                                    ToolTip="자동 블로팅 시퀀스 시작">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="☆" FontSize="18" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="자동 블로팅"   FontSize="14" FontWeight="Black" Foreground="White"/>
                                        <TextBlock Text="AUTO BLOTTING"   FontSize="9"  Foreground="#67E8F9"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- STOP — 진행 중인 자동 시퀀스 취소. 실행 중일 때만 활성 -->
                            <Button Height="48" Margin="0,0,0,12"
                                    Style="{StaticResource MutedActionButtonStyle}" Background="#B91C1C"
                                    Command="{Binding StopAutoSequenceCommand}"
                                    ToolTip="진행 중인 자동 시퀀스 즉시 중단">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="■" FontSize="16" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="중지"   FontSize="13" FontWeight="Black" Foreground="White"/>
                                        <TextBlock Text="STOP"   FontSize="9"  Foreground="#FCA5A5"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Rectangle Height="1" Fill="#1E293B" Margin="0,4,0,8"/>

                            <!-- 단위 동작 (2x4 그리드) -->
                            <TextBlock Text="MANUAL OPERATIONS" Foreground="#FBBF24"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="44"/>
                                </Grid.RowDefinitions>

                                <!-- Row 1: REFILL / PURGE -->
                                <Button Grid.Row="0" Grid.Column="0"
                                        Style="{StaticResource MutedActionButtonStyle}" Background="#1E40AF">
                                    <StackPanel>
                                        <TextBlock Text="잉크 충전" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="REFILL"   FontSize="9"  Foreground="#93C5FD" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="0" Grid.Column="2"
                                        Command="{Binding TogglePurgeCommand}"
                                        ToolTip="P&amp;ID 헤드 노즐 퍼지 애니메이션 ON/OFF">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MutedActionButtonStyle}">
                                            <Setter Property="Background" Value="#A16207"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPurging}" Value="True">
                                                    <Setter Property="Background" Value="#CA8A04"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="퍼지"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPurging}" Value="True">
                                                            <Setter Property="Text" Value="퍼지 중지"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="9" Foreground="#FDE68A" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="PURGE"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPurging}" Value="True">
                                                            <Setter Property="Text" Value="PURGE STOP"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <!-- Row 2: SPITTING / DRAIN -->
                                <Button Grid.Row="2" Grid.Column="0"
                                        Command="{Binding ToggleSpittingCommand}"
                                        ToolTip="P&amp;ID 헤드 노즐 spit 애니메이션 ON/OFF">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MutedActionButtonStyle}">
                                            <Setter Property="Background" Value="#1E40AF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSpitting}" Value="True">
                                                    <Setter Property="Background" Value="#3B82F6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="스피팅"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSpitting}" Value="True">
                                                            <Setter Property="Text" Value="스피팅 중지"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="9" Foreground="#93C5FD" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="SPITTING"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSpitting}" Value="True">
                                                            <Setter Property="Text" Value="SPITTING STOP"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="2" Grid.Column="2"
                                        Style="{StaticResource MutedActionButtonStyle}" Background="#A16207">
                                    <StackPanel>
                                        <TextBlock Text="드레인"   FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="DRAIN"    FontSize="9"  Foreground="#FDE68A" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Row 3: P+ ON / P- ON (활성화 시 PMC 양압/음압 배관 flow 애니메이션) -->
                                <Button Grid.Row="4" Grid.Column="0"
                                        Command="{Binding TogglePositivePressureCommand}"
                                        ToolTip="PMC 양압(P+) 배관 flow ON/OFF">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MutedActionButtonStyle}">
                                            <Setter Property="Background" Value="#9A3412"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPositivePressureEnabled}" Value="True">
                                                    <Setter Property="Background" Value="#EA580C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="양압 ON"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPositivePressureEnabled}" Value="True">
                                                            <Setter Property="Text" Value="양압 OFF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="P+ ENABLE" FontSize="9"  Foreground="#FDBA74" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="4" Grid.Column="2"
                                        Command="{Binding ToggleVacuumCommand}"
                                        ToolTip="PMC 음압(P-) 배관 flow ON/OFF">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MutedActionButtonStyle}">
                                            <Setter Property="Background" Value="#6B21A8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVacuumEnabled}" Value="True">
                                                    <Setter Property="Background" Value="#9333EA"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="음압 ON"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsVacuumEnabled}" Value="True">
                                                            <Setter Property="Text" Value="음압 OFF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="P- ENABLE" FontSize="9"  Foreground="#D8B4FE" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Row 4: VALVE OPEN ALL / CLOSE ALL — H1-1~H8-2 (Y700~Y715) 일괄 -->
                                <Button Grid.Row="6" Grid.Column="0"
                                        Style="{StaticResource MutedActionButtonStyle}" Background="#15803D"
                                        Command="{Binding OpenAllHeadValvesCommand}"
                                        ToolTip="H1-1 ~ H8-2 (Y700~Y715) 16개 밸브 일괄 OPEN">
                                    <StackPanel>
                                        <TextBlock Text="전체 OPEN"  FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="ALL VALVES" FontSize="9"  Foreground="#86EFAC" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="6" Grid.Column="2"
                                        Style="{StaticResource MutedActionButtonStyle}" Background="#475569"
                                        Command="{Binding CloseAllHeadValvesCommand}"
                                        ToolTip="H1-1 ~ H8-2 (Y700~Y715) 16개 밸브 일괄 CLOSE">
                                    <StackPanel>
                                        <TextBlock Text="전체 CLOSE" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="ALL VALVES" FontSize="9"  Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
