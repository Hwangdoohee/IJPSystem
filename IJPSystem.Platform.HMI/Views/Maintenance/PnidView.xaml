<UserControl x:Class="IJPSystem.Platform.HMI.Views.PnidView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:IJPSystem.Platform.HMI.Common.Controls"
             Background="#0F172A">

    <UserControl.Resources>
        <!-- ── Pipe / Component 색상 규약 ── -->
        <SolidColorBrush x:Key="ChemPipe"  Color="#3B82F6"/>
        <!-- 잉크 공급/순환 -->
        <SolidColorBrush x:Key="DrainPipe" Color="#EAB308"/>
        <!-- 드레인 -->
        <SolidColorBrush x:Key="PresPipe"  Color="#F97316"/>
        <!-- 양압 (+) -->
        <SolidColorBrush x:Key="VacPipe"   Color="#A855F7"/>
        <!-- 음압 (-) -->
        <SolidColorBrush x:Key="InstrLine" Color="#64748B"/>
        <!-- 계장 신호선 -->

        <SolidColorBrush x:Key="EquipFill" Color="#1E293B"/>
        <SolidColorBrush x:Key="EquipEdge" Color="#475569"/>
        <SolidColorBrush x:Key="TextDim"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextWeak"  Color="#475569"/>
        <Style x:Key="PnidValveToggle" TargetType="ToggleButton">
            <Setter Property="Width"      Value="26"/>
            <Setter Property="Height"     Value="24"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="Focusable"  Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <Polygon x:Name="Bow"
                          Points="0,0 26,0 13,12 26,24 0,24 13,12"
                          Stroke="{TemplateBinding BorderBrush}"
                          StrokeThickness="1.8"
                          Fill="{TemplateBinding Background}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bow" Property="Fill"   Value="#22C55E"/>
                                <Setter TargetName="Bow" Property="Stroke" Value="#22C55E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bow" Property="StrokeThickness" Value="2.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 배관 flow 애니메이션 (대시 오프셋 회전) ── -->
        <Style x:Key="DashFlow" TargetType="Shape">
            <Setter Property="StrokeDashArray" Value="6 3"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset"
                                  From="9" To="0" Duration="0:0:1.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>


        <!-- ── 인터랙티브 Print Head (ToggleButton) — 클릭 시 사용/미사용 토글 ──
          IsChecked=True(사용) → 청색 stroke / 정상 표시
          IsChecked=False(미사용) → 회색 stroke / 반투명 -->
        <Style x:Key="PrintHeadToggle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="50"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment"   Value="Top"/>
            <Setter Property="Padding" Value="6,3,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <Rectangle x:Name="Body"
                                    Stroke="{StaticResource ChemPipe}" StrokeThickness="1.5"
                                    Fill="{StaticResource EquipFill}"
                                    RadiusX="2" RadiusY="2"/>
                            <ContentPresenter x:Name="Label"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Body"  Property="Stroke"  Value="#475569"/>
                                <Setter TargetName="Body"  Property="Opacity" Value="0.35"/>
                                <Setter TargetName="Label" Property="Opacity" Value="0.35"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Body" Property="StrokeThickness" Value="2.2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 조건부 배관 flow 애니메이션 ──
          각 Shape 의 Tag 에 활성 조건(예: IsPositivePressureEnabled, IsVacuumEnabled, Sv101Open) 바인딩
          → True 일 때만 점선 flow, False 시 실선 -->
        <Style x:Key="PmcPipeFlow" TargetType="Shape">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="StrokeDashArray" Value="6 3"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PmcPipeFlowSb">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset"
                                              From="9" To="0" Duration="0:0:1.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="PmcPipeFlowSb"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── BATH → DB-101 드레인 flow 애니메이션 ──
          AnyHeadPurging=True (퍼지 ON 이고 8헤드 중 1개 이상 밸브 열림) 일 때만 점선이 흐르는 효과 -->
        <Style x:Key="PurgeDrainFlow" TargetType="Path">
            <Style.Triggers>
                <DataTrigger Binding="{Binding AnyHeadPurging}" Value="True">
                    <Setter Property="StrokeDashArray" Value="4 2"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PurgeDrainFlowSb">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset"
                                              From="6" To="0" Duration="0:0:0.4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="PurgeDrainFlowSb"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── 노즐 퍼지 애니메이션 ──
          각 요소의 Tag 에 헤드별 HeadXPurging 바인딩 → IsPurging 이고 해당 head 의 밸브가 열린 경우에만 동작 -->
        <Style x:Key="NozzlePulse" TargetType="Rectangle">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="NozzlePulseSb">
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                              From="1.0" To="0.35" Duration="0:0:0.18"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="NozzlePulseSb"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NozzleDrop" TargetType="Ellipse">
            <Setter Property="Width"   Value="4"/>
            <Setter Property="Height"  Value="6"/>
            <Setter Property="Fill"    Value="#3B82F6"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="NozzleDropSb">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                              From="0" To="32" Duration="0:0:0.28"/>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity" Duration="0:0:0.28">
                                    <LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                    <LinearDoubleKeyFrame KeyTime="0:0:0.05" Value="1"/>
                                    <LinearDoubleKeyFrame KeyTime="0:0:0.22" Value="1"/>
                                    <LinearDoubleKeyFrame KeyTime="0:0:0.28" Value="0"/>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="NozzleDropSb"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── 노즐 SPIT 스트림 애니메이션 ──
             퍼지의 한 방울 낙하와 달리, spit은 작은 방울이 연속으로 흐르는 가는 점선처럼 동작
             StrokeDashOffset을 빠르게 순환시켜 점들이 아래로 흘러내리는 느낌을 줌 -->
        <Style x:Key="NozzleSpitStream" TargetType="Line">
            <Setter Property="Stroke"          Value="#3B82F6"/>
            <Setter Property="StrokeThickness" Value="1.4"/>
            <Setter Property="StrokeDashArray" Value="1 1.5"/>
            <Setter Property="StrokeDashCap"   Value="Round"/>
            <Setter Property="X1" Value="0"/>
            <Setter Property="Y1" Value="0"/>
            <Setter Property="X2" Value="0"/>
            <Setter Property="Y2" Value="30"/>
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="NozzleSpitStreamSb">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset"
                                              From="2.5" To="0" Duration="0:0:0.14"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="NozzleSpitStreamSb"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── 영역 그룹 배경 패널 ── -->
        <Style x:Key="GroupPanel" TargetType="Rectangle">
            <Setter Property="Fill"            Value="#13213A"/>
            <Setter Property="Stroke"          Value="#1E2D45"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeDashArray" Value="3 3"/>
            <Setter Property="RadiusX"         Value="6"/>
            <Setter Property="RadiusY"         Value="6"/>
            <Setter Property="Opacity"         Value="0.55"/>
        </Style>
        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>


        <!-- 태그 박스 -->
        <Style x:Key="TagBox" TargetType="Border">
            <Setter Property="Background"      Value="#1E293B"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Padding"         Value="4,1"/>
        </Style>


        <!-- 시퀀스 단계 스타일 -->
        <Style x:Key="StepNumBadge" TargetType="Border">
            <Setter Property="Width"  Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="StepNumText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="StepDesc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>


    </UserControl.Resources>

    <Grid>
        <!-- ── Main Layout: Canvas | Sequence Panel ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════════════════════════════════
                 좌측: P&ID Canvas
            ════════════════════════════════════════ -->
            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Canvas Width="940" Height="721" Background="#0F172A">

                    <!-- ════════════════════════════════
                         영역 그룹 배경 패널 (시각적 그룹핑)
                         Canvas 최상단에 배치 → 모든 장비/배관이 위에 그려짐
                    ════════════════════════════════ -->
                    <Rectangle Style="{StaticResource GroupPanel}"
                               Canvas.Left="10" Canvas.Top="0" Width="920" Height="110"/>
                    <TextBlock Style="{StaticResource GroupLabel}"
                               Canvas.Left="800" Canvas.Top="6" Text="◆ PRESSURE CONTROL"/>

                    <Rectangle Style="{StaticResource GroupPanel}"
                               Canvas.Left="10" Canvas.Top="115" Width="920" Height="408"/>
                    <TextBlock Style="{StaticResource GroupLabel}"
                               Canvas.Left="22" Canvas.Top="121" Text="◆ INK FLOW PATH (Canister → Reservoir → 8 Heads)"/>

                    <Rectangle Style="{StaticResource GroupPanel}"
                               Canvas.Left="10" Canvas.Top="528" Width="920" Height="203" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <TextBlock Style="{StaticResource GroupLabel}"
                               Canvas.Left="22" Canvas.Top="534" Text="◆ PURGE / DRAIN"/>

                    <!-- ════════════════════════════════
                         PMC (좌상단)
                    ════════════════════════════════ -->
                    <ctl:PMC Canvas.Left="40" Canvas.Top="2"
                             PressurePV="{Binding PressurePV}"
                             PressureSV="{Binding PressureSV, Mode=TwoWay}"
                             VacuumPV="{Binding VacuumPV}"
                             VacuumSV="{Binding VacuumSV, Mode=TwoWay}"
                             SetPressureCommand="{Binding SetPressureCommand}"
                             SetVacuumCommand="{Binding SetVacuumCommand}"/>

                    <!-- PMC → CANISTER (양압) — 배선이므로 화살표 없음, IsPositivePressureEnabled=True 시 flow -->
                    <Path Style="{StaticResource PmcPipeFlow}"
                          Tag="{Binding IsPositivePressureEnabled}"
                          Stroke="{StaticResource PresPipe}" StrokeThickness="2"
                          Data="M 320,47 L 365,47 L 365,170 L 105,170 L 105,191"/>

                    <!-- PMC → RESERVOIR (양압) — 배선이므로 화살표 없음 -->
                    <Path Style="{StaticResource PmcPipeFlow}"
                          Tag="{Binding IsPositivePressureEnabled}"
                          Stroke="{StaticResource PresPipe}" StrokeThickness="2"
                          Data="M 320,62 L 480,62 L 480,180"/>

                    <!-- PMC → RESERVOIR (음압) — 배선이므로 화살표 없음 -->
                    <Path Style="{StaticResource PmcPipeFlow}"
                          Tag="{Binding IsVacuumEnabled}"
                          Stroke="{StaticResource VacPipe}" StrokeThickness="2"
                          Data="M 320,80 L 510,80 L 510,180"/>

                    <!-- ════════════════════════════════
                         CANISTER (좌중앙)
                    ════════════════════════════════ -->
                    <ctl:Canister Canvas.Left="60" Canvas.Top="200"
                                  TagId="CN-101" Caption="잉크 공급 (Bottle 1)"
                                  LevelStatus="Set"
                                  SensorDetect="{Binding Bottle1Detect}"
                                  SensorLeak="{Binding Bottle1Leak}"
                                  SensorHigh="{Binding Bottle1High}"/>
                    <!-- CN → SV-101 출구 배관 (Sv101Open=True 시 flow) -->
                    <Line X1="150" Y1="240" X2="240" Y2="240"
                          Style="{StaticResource PmcPipeFlow}"
                          Tag="{Binding Sv101Open}"
                          Stroke="{StaticResource ChemPipe}" StrokeThickness="3"/>

                    <!-- ════════════════════════════════
                         CN → RV 공급 밸브 SV-101 (클릭 토글)
                    ════════════════════════════════ -->
                    <ToggleButton Canvas.Left="240" Canvas.Top="228"
                                  Style="{StaticResource PnidValveToggle}"
                                  BorderBrush="{StaticResource ChemPipe}"
                                  IsChecked="{Binding Sv101Open, Mode=TwoWay}"
                                  ToolTip="SV-101 (CN → RV) — 클릭하여 OPEN/CLOSE"/>
                    <Ellipse Canvas.Left="244" Canvas.Top="210" Width="18" Height="18"
                             Stroke="#64748B" StrokeThickness="1.5" Fill="#1E3A5F" IsHitTestVisible="False"/>
                    <TextBlock Canvas.Left="248" Canvas.Top="214" Text="SV" Foreground="#93C5FD" FontSize="7" FontWeight="Bold" IsHitTestVisible="False"/>
                    <Border Canvas.Left="237" Canvas.Top="258" Style="{StaticResource TagBox}">
                        <TextBlock Text="SV-101" Foreground="#60A5FA" FontSize="9" FontFamily="Consolas"/>
                    </Border>
                    <!-- SV-101 → RV 공급 배관 (Sv101Open=True 시 flow) -->
                    <Line X1="266" Y1="240" X2="300" Y2="240"
                          Style="{StaticResource PmcPipeFlow}"
                          Tag="{Binding Sv101Open}"
                          Stroke="{StaticResource ChemPipe}" StrokeThickness="3"/>
                    <!-- 레저버 쪽 화살표 — 라인 끝(420,240) 에 우측 방향 삼각형, 중앙 y=240 -->
                    <Polygon Canvas.Left="293" Canvas.Top="233" Points="0,0 0,14 8,7" Fill="{StaticResource ChemPipe}"/>

                    <!-- ════════════════════════════════════════════════════════════════
                         ▶ 우측 시프트 영역 (Canvas.Left=100)
                         Reservoir + Manifold + 8 Heads + Valves + PurgeBath + DrainBottles + SlotDie
                         이 wrapper canvas 내부 좌표는 원본 유지, +100 px 우측으로 보임
                    ════════════════════════════════════════════════════════════════ -->
                    <Canvas Canvas.Left="100" Canvas.Top="0">

                    <!-- ════════════════════════════════
                         RESERVOIR (가로 직사각형) + PT-101
                    ════════════════════════════════ -->
                    <ctl:Reservoir Canvas.Left="200" Canvas.Top="180"
                                   TagId="RV-101" 
                                   LevelStatus="{Binding ReservoirLevel}"
                                   SensorHH="{Binding ReservoirOverflow}"
                                   SensorHigh="{Binding ReservoirHigh}"
                                   SensorSet="{Binding ReservoirSet}"
                                   SensorEmpty="{Binding ReservoirEmpty}"/>

                    <!-- PT-101 (압력 트랜스미터) — 신호선 + 버블 -->
                    <Line X1="500" Y1="155" X2="500" Y2="180"
                          Stroke="{StaticResource InstrLine}" StrokeThickness="1" StrokeDashArray="2,2"/>
                    <ctl:InstrumentBubble Canvas.Left="487" Canvas.Top="116" Type="PT" TagId="PT-101"/>

                    <!-- ════════════════════════════════
                         RESERVOIR 하단 16-WAY 분배 매니폴드 (공통 HEADER)
                         16개 inlet 배관이 이 헤더에서 분기되어 각 헤드로 공급
                    ════════════════════════════════ -->
                    <!-- 헤더 본체 -->
                    <Rectangle Canvas.Left="195" Canvas.Top="298" Width="530" Height="18"
                               Fill="{StaticResource EquipFill}"
                               Stroke="{StaticResource ChemPipe}" StrokeThickness="2"
                               RadiusX="3" RadiusY="3"/>
                    <!-- 내부 하이라이트 (입체감) -->
                    <Line X1="200" Y1="304" X2="720" Y2="304"
                          Stroke="#3B82F6" StrokeThickness="1" Opacity="0.5"/>
                    <!-- 헤더 태그 -->
                    <Border Canvas.Left="730" Canvas.Top="300" Style="{StaticResource TagBox}">
                        <TextBlock Text="HDR-101" Foreground="#60A5FA" FontSize="8" FontFamily="Consolas"/>
                    </Border>

                    <!-- ════════════════════════════════
                         RV → 8 HEADS 직접 공급 (각 헤드당 2개 배관)
                         pipe 상단은 매니폴드를 통과 (y=300~316 매니폴드 내부) → 매니폴드에서 분기되는 형상
                    ════════════════════════════════ -->

                    <!-- ════════════════════════════════
                         8 PRINT HEADS (균등 60px 간격, 박스 width 40)
                         centers: 250, 310, 370, 430, 490, 550, 610, 670 (reservoir 200-720 안에 균등)
                         pipes at box left/right edges → 16 inlet pipes from y=300 to y=465
                         valves staggered: left=upper(y=370), right=lower(y=410)
                    ════════════════════════════════ -->

                    <!-- ─── H1 ─── -->
                    <Line X1="230" Y1="300" X2="230" Y2="465" Stroke="{StaticResource ChemPipe}" StrokeThickness="1.5"/>
                    <Line X1="270" Y1="300" X2="270" Y2="465" Stroke="{StaticResource ChemPipe}" StrokeThickness="1.5"/>
                    <ToggleButton Canvas.Left="225" Canvas.Top="465"
                                  Style="{StaticResource PrintHeadToggle}"
                                  IsChecked="{Binding Head1Enabled, Mode=TwoWay}"
                                  ToolTip="H1 — 클릭하여 사용/미사용 전환">
                        <TextBlock Text="H1" Foreground="#93C5FD" FontSize="9" FontFamily="Consolas" FontWeight="Bold"/>
                    </ToggleButton>
                    <Rectangle Canvas.Left="238" Canvas.Top="495" Width="24" Height="4" Fill="#3B82F6" Style="{StaticResource NozzlePulse}" Tag="{Binding Head1Active}"/>
                    <Ellipse Canvas.Left="248" Canvas.Top="499" Width="4" Height="6" Fill="#3B82F6"/>
                    <Ellipse Canvas.Left="248" Canvas.Top="505" Style="{StaticResource NozzleDrop}" Tag="{Binding Head1Purging}"/>
                    <Line Canvas.Left="240" Canvas.Top="506" Style="{StaticResource NozzleSpitStream}" Tag="{Binding Head1Spitting}"/>
                    <Line Canvas.Left="245" Canvas.Top="506" Style="{StaticResource NozzleSpitStream}" Tag="{Binding Head1Spitting}"/>
                    <Line Canvas.Left="250" Canvas.Top="506" Style="{StaticResource NozzleSpitStream}" Tag="{Binding Head1Spitting}"/>
                    <Line Canvas.Left="255" Canvas.Top="506" Style="{StaticResource NozzleSpitStream}" Tag="{Binding Head1Spitting}"/>
                    <Line Canvas.Left="260" Canvas.Top="506" Style="{StaticResource NozzleSpitStream}" Tag="{Binding Head1Spitting}"/>
                    <ToggleButton Canvas.Left="217" Canvas.Top="358" Style="{StaticResource PnidValveToggle}" BorderBrush="{StaticResource ChemPipe}" IsChecked="{Binding Pack1H1In, Mode=TwoWay}" ToolTip="Y700 (H1 Inlet 1)"/>
                    <Border Canvas.Left="217" Canvas.Top="384" Style="{StaticResource TagBox}">
                        <TextBlock Text="H1-1" Foreground="#60A5FA" FontSize="8" FontFamily="Consolas"/>
                    </Border>
                    <ToggleButton Canvas.Left="257" Canvas.Top="398" Style="{StaticResource PnidValveToggle}" BorderBrush="{StaticResource ChemPipe}" IsChecked="{Binding Pack1H1Out, Mode=TwoWay}" ToolTip="Y701 (H1 Inlet 2)"/>
                    <Border Canvas.Left="257" Canvas.Top="424" Style="{StaticResource TagBox}">
                        <TextBlock Text="H1-2" Foreground="#60A5FA" FontSize="8" FontFamily="Consolas"/>
                    </Border>

                    <!-- ─── H2 ─── -->
