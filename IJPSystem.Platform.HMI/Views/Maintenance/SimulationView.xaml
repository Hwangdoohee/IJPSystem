<UserControl x:Class="IJPSystem.Platform.HMI.Views.SimulationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             Background="#0F172A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header + 액션 버튼 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🧪" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="SIMULATOR" Foreground="#3B82F6" FontWeight="Black" FontSize="18"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" — 시나리오 기반 시퀀스 회귀 검증"
                           Foreground="#94A3B8" FontSize="12" VerticalAlignment="Bottom" Margin="8,0,0,2"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="🔄 RELOAD"  Command="{Binding ReloadCommand}"  Width="100" Height="34" Margin="0,0,8,0"
                        Background="#1E293B"  Foreground="#94A3B8" BorderBrush="#334155" BorderThickness="1" FontWeight="Bold"/>
                <Button Content="▶ RUN"      Command="{Binding RunCommand}"     Width="100" Height="34" Margin="0,0,8,0"
                        Background="#1D4ED8"  Foreground="White"   BorderThickness="0" FontWeight="Bold"/>
                <Button Content="▶▶ RUN ALL" Command="{Binding RunAllCommand}"  Width="120" Height="34"
                        Background="#7F1D1D"  Foreground="White"   BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <!-- 시나리오 폴더 안내 -->
        <Border Grid.Row="1" Background="#0B1220" CornerRadius="6" Padding="10,6" Margin="0,0,0,10"
                BorderBrush="#1E293B" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📂" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ScenarioFolderPath}" Foreground="#64748B"
                           FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 시나리오 리스트 -->
        <Border Grid.Row="2" Background="#1E293B" CornerRadius="8"
                BorderBrush="#334155" BorderThickness="1" Padding="6">
            <DataGrid ItemsSource="{Binding Scenarios}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" Background="Transparent" Foreground="White"
                      BorderThickness="0" HeadersVisibility="Column" RowBackground="#111827"
                      AlternatingRowBackground="#1A2233" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2D3748" RowHeight="40" ColumnHeaderHeight="36"
                      CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="시나리오"   Binding="{Binding Def.Name}"         Width="2*"/>
                    <DataGridTextColumn Header="시퀀스"     Binding="{Binding Def.Sequence}"     Width="120"/>
                    <DataGridTextColumn Header="기대"       Binding="{Binding Def.Expect.Result}" Width="100"/>
                    <DataGridTextColumn Header="상태"       Binding="{Binding Status}"           Width="3*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 마지막 실행 결과 -->
        <Border Grid.Row="3" Margin="0,12,0,0" Background="#0B1220" CornerRadius="6" Padding="14,10"
                BorderBrush="#1E40AF" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="LAST RESULT — " Foreground="#64748B" FontSize="12" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LastResult}" Foreground="#86EFAC"
                           FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
