<UserControl x:Class="IJPSystem.Platform.HMI.Views.IOMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"             
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="#0F172A">

    <Grid Margin="15,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E293B" CornerRadius="10" Padding="15,8" Margin="0,0,0,10" BorderBrush="#334155" BorderThickness="1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍" Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Grid Width="300">
                        <TextBox x:Name="TxtSearch" Background="Transparent"
                                 Foreground="White" CaretBrush="White" BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Search address, name, description..."
                                Foreground="#475569" FontStyle="Italic"
                                VerticalAlignment="Center" Margin="2,0"
                                IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" Text="I/O MONITORING SYSTEM" Foreground="#3B82F6" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#1E293B" CornerRadius="12" BorderBrush="#334155" BorderThickness="1" Padding="15">
            <TabControl Background="Transparent" BorderThickness="0">

                <TabItem Header="INPUT (DI)">
                    <DataGrid x:Name="dgInput" ItemsSource="{Binding InputList}" 
                              Style="{StaticResource CommonDataGridStyle}" 
                              ColumnHeaderStyle="{StaticResource CommonColumnHeaderStyle}"
                              CellStyle="{StaticResource CommonCellStyle}" Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ADDR" Binding="{Binding Address}" Width="80"/>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Index}" Width="400"/>
                            <DataGridTemplateColumn Header="STATUS" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="10" Height="10" Fill="{Binding HardwareSignal, Converter={StaticResource SignalToColorConverter}}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="TYPE" Binding="{Binding ContactType}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="OUTPUT (DO)">
                    <DataGrid x:Name="dgOutput" ItemsSource="{Binding OutputList}" 
                              Style="{StaticResource CommonDataGridStyle}" 
                              ColumnHeaderStyle="{StaticResource CommonColumnHeaderStyle}"
                              CellStyle="{StaticResource CommonCellStyle}" Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="CONTROL" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding HardwareSignal, Converter={StaticResource SignalToTextConverter}}" 
                                                Command="{Binding ToggleCommand}" 
                                                Height="24" Width="65" FontSize="10" FontWeight="Bold" Foreground="White">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" Background="#475569" CornerRadius="12">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding HardwareSignal}" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#3B82F6"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="ADDR" Binding="{Binding Address}" Width="80"/>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Index}" Width="400"/>
                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="TYPE" Binding="{Binding ContactType}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="ANALOG INPUT (AI)">
                    <DataGrid x:Name="agInput" ItemsSource="{Binding AnalogInputList}" 
                            Style="{StaticResource CommonDataGridStyle}" 
                            ColumnHeaderStyle="{StaticResource CommonColumnHeaderStyle}"
                            CellStyle="{StaticResource CommonCellStyle}" Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ADDR" Binding="{Binding Address}" Width="100"/>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Index}" Width="400"/>
                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="350"/>
                            <DataGridTemplateColumn Header="INPUT VALUE" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,4">
                                            <Border Background="#0F172A" CornerRadius="10" Height="18">
                                                <ProgressBar Value="{Binding AnalogValue}"
                                             Minimum="{Binding MinValue}"
                                             Maximum="{Binding MaxValue}"
                                             Background="Transparent" Foreground="#10B981" BorderThickness="0"/>
                                            </Border>
                                            <TextBlock Text="{Binding AnalogValue, StringFormat={}{0:F1}}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="UNIT" Binding="{Binding Unit}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="ANALOG OUTPUT (AO)">
                    <DataGrid x:Name="agOutput" ItemsSource="{Binding AnalogOutputList}"
                                Style="{StaticResource CommonDataGridStyle}" Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ADDR"        Binding="{Binding Address}"     Width="100"/>
                            <DataGridTextColumn Header="NAME"        Binding="{Binding Index}"       Width="400"/>
                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="200"/>

                            <!-- 현재 출력값 모니터링 -->
                            <DataGridTemplateColumn Header="CURRENT VALUE" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,4">
                                            <Border Background="#0F172A" CornerRadius="10" Height="18">
                                                <ProgressBar Value="{Binding AnalogValue}"
                                             Minimum="{Binding MinValue}"
                                             Maximum="{Binding MaxValue}"
                                             Background="Transparent"
                                             Foreground="#3B82F6"
                                             BorderThickness="0"/>
                                            </Border>
                                            <TextBlock Text="{Binding AnalogValue, StringFormat={}{0:F2}}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 설정값 입력 + SET 버튼 -->
                            <DataGridTemplateColumn Header="SET VALUE" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,4">
                                            <TextBox Width="80" Height="26"
                                                     Text="{Binding AnalogSetValue, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#0F172A" Foreground="White"
                                                     CaretBrush="White"
                                                     BorderBrush="#334155" BorderThickness="1"
                                                     VerticalContentAlignment="Center"
                                                     Padding="6,0"/>
                                            <TextBlock Text="{Binding Unit}"
                                                       Foreground="#64748B" FontSize="11"
                                                       VerticalAlignment="Center" Margin="6,0"/>
                                            <Button Content="SET"
                                                    Command="{Binding SetAnalogCommand}"
                                                    Width="50" Height="26"
                                                    FontSize="11" FontWeight="Bold"
                                                    Foreground="White" Background="#3B82F6"
                                                    Margin="6,0,0,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="BtnBorder"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="UNIT" Binding="{Binding Unit}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>