<UserControl x:Class="IJPSystem.Platform.HMI.Views.MotorControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:cvts="clr-namespace:IJPSystem.Platform.HMI.Common.Converters" 
             mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1200"
             Background="#0F172A">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E293B" CornerRadius="6" Padding="12,5" Margin="0,0,0,10" BorderBrush="#334155" BorderThickness="1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙️" Foreground="#94A3B8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="MOTOR CONTROL CENTER" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Total Axes: " Foreground="#94A3B8" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding AxisList.Count}" Foreground="#3B82F6" FontSize="12" FontWeight="ExtraBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E293B" CornerRadius="10" BorderBrush="#334155" BorderThickness="1" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- AXIS SELECT & MOTION 패널 상단에 추가 -->
                    <Border Background="#0F172A" CornerRadius="6" Padding="10,6" 
                            Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CURRENT POS" Foreground="#64748B" FontSize="9"/>
                                <TextBlock Text="{Binding SelectedAxis.Status.CurrentPos, StringFormat={}{0:F3}}"
                                            Foreground="#22C55E" FontWeight="Bold" FontFamily="Consolas" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="SERVO" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                                         Fill="{Binding SelectedAxis.Status.IsServoOn, 
                                                Converter={StaticResource SignalToColorConverter}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock Text="IN POSITION" Foreground="#64748B" FontSize="9" HorizontalAlignment="Right"/>
                                <Ellipse Width="10" Height="10" HorizontalAlignment="Right"
                                         Fill="{Binding SelectedAxis.Status.IsInPosition, 
                                                Converter={StaticResource SignalToColorConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Row="0" Background="#243146" CornerRadius="10,10,0,0">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="AXIS" Foreground="#94A3B8" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="MOTOR NAME" Foreground="#94A3B8" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>

                            <TextBlock Grid.Column="2"
                                       Foreground="#94A3B8" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Run Text="STATUS " FontSize="11"/>
                                <Run Text="(Servo/Orgin/InPos)" FontSize="9"/>
                            </TextBlock>
                            <TextBlock Grid.Column="3" Text="MOTOR SENSOR" Foreground="#94A3B8" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Column="4" Text="POSITION(mm)" Foreground="#94A3B8" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Column="5" Text="ACTION" Foreground="#94A3B8" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                        </Grid>

                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AxisList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Height="50">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"       Value="Transparent"/>
                                                <Setter Property="BorderBrush"      Value="#334155"/>
                                                <Setter Property="BorderThickness"  Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status.IsMoving}" Value="True">
                                                        <Setter Property="Background" Value="#06204A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status.IsAlarm}" Value="True">
                                                        <Setter Property="Background"      Value="#2D0A0A"/>
                                                        <Setter Property="BorderBrush"     Value="#EF4444"/>
                                                        <Setter Property="BorderThickness" Value="2,1,2,1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Margin="10,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Info.AxisNo}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Consolas"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Info.Name}" Foreground="#CBD5E1" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0" FontSize="12"/>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse Width="10" Height="10" Margin="4,0" Fill="{Binding Status.IsServoOn, Converter={StaticResource SignalToColorConverter}}" ToolTip="Servo On"/>
                                                <Ellipse Width="10" Height="10" Margin="4,0" Fill="{Binding Status.IsHomeDone, Converter={StaticResource SignalToColorConverter}}" ToolTip="Home Done"/>
                                                <Ellipse Width="10" Height="10" Margin="4,0" Fill="{Binding Status.IsInPosition, Converter={StaticResource SignalToColorConverter}}" ToolTip="In Position"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border Width="28" Height="16" CornerRadius="4" Margin="3,0" Background="{Binding Status.CwLimit, Converter={StaticResource SensorToBgConverter}}" ToolTip="CW Limit">
                                                    <TextBlock Text="CW" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Width="32" Height="16" CornerRadius="4" Margin="3,0" Background="{Binding Status.CcwLimit, Converter={StaticResource SensorToBgConverter}}" ToolTip="CCW Limit">
                                                    <TextBlock Text="CCW" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Width="38" Height="16" CornerRadius="4" Margin="3,0" Background="{Binding Status.HomeSensor, Converter={StaticResource SensorToBgConverter}}" ToolTip="Home Sensor">
                                                    <TextBlock Text="HOME" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>

                                            <Border Grid.Column="4" Background="#0F172A" CornerRadius="4" Height="28" Margin="5,0" BorderBrush="#334155" BorderThickness="1">
                                                <TextBlock Text="{Binding Status.CurrentPos, StringFormat={}{0:F3}}"
                                               Foreground="#22C55E" FontWeight="Bold" FontFamily="Consolas" 
                                               VerticalAlignment="Center" HorizontalAlignment="Right" 
                                               Margin="8,0" FontSize="13"/>
                                            </Border>

                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="SERVO" Command="{Binding ServoCommand}" Width="52" Margin="2" FontSize="10">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ModernActionButton}">
                                                            <Setter Property="Background" Value="#475569"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status.IsServoOn}" Value="true">
                                                                    <Setter Property="Background" Value="#22C55E"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="HOME" Command="{Binding HomeCommand}" Style="{StaticResource ModernActionButton}" Background="#475569" Width="52" Margin="2" FontSize="10"/>
                                                <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource ModernActionButton}" Background="#EF4444" Width="52" Margin="2" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E293B" CornerRadius="10" Padding="15,15,15,10" Margin="0,0,0,5" BorderBrush="#334155" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="MASTER CONTROL" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>

                            <Button Grid.Row="1" Grid.Column="0" Command="{Binding AllHomeCommand}"
                                Background="#2D3A4F" BorderBrush="#3B82F6" BorderThickness="1.5"
                                Height="55" Margin="0,0,4,0" VerticalAlignment="Center" Style="{StaticResource ModernActionButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🏠" FontSize="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="All HOME" FontSize="12" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="1" Grid.Column="1" Command="{Binding AllServoOnCommand}"
                                Background="#1E293B" BorderBrush="#10B981" BorderThickness="1.5"
                                Height="55" Margin="0,0,4,0" Style="{StaticResource ModernActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Servo ON" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="1" Grid.Column="2" Command="{Binding AllServoOffCommand}"
                                Background="#1E293B" BorderBrush="#64748B" BorderThickness="1.5"
                                Height="55" Margin="0,0,4,0" Style="{StaticResource ModernActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="15" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Servo OFF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="1" Grid.Column="3" Command="{Binding AllStopCommand}"
                                Background="#1E293B" BorderBrush="#EF4444" BorderThickness="1.5"
                                Height="55" Style="{StaticResource ModernActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛑" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="All STOP" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Foreground="#EF4444"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Background="#1E293B" CornerRadius="10" Padding="15,15,15,0" Margin="0,0,0,5" BorderBrush="#334155" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="AXIS SELECT &amp; MOTION" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="Select Axis" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="11"/>
                                <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                                          ItemsSource="{Binding AxisList}" 
                                          SelectedItem="{Binding SelectedAxis}" 
                                          DisplayMemberPath="Info.Name" 
                                          Height="35" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                            </Grid>
                            <Separator Background="#334155" Margin="1,5"/>
                            <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="Moving Method" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="11"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <RadioButton Content="ABS" 
                                                         IsChecked="{Binding SelectedAxis.IsAbsMode, Mode=TwoWay}" 
                                                         GroupName="MoveMethod"
                                                         Style="{StaticResource ModernModeButtonStyle}"/>
                                            <RadioButton Content="INC" 
                                                         IsChecked="{Binding SelectedAxis.IsIncMode, Mode=TwoWay}" 
                                                         Margin="5,0,0,0" 
                                                         GroupName="MoveMethod"
                                                         Style="{StaticResource ModernModeButtonStyle}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Target Position" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="11"/>
                                        <Border Background="#0F172A" CornerRadius="4" BorderBrush="#334155" BorderThickness="1" HorizontalAlignment="Right" Width="120" Height="28">
                                            <TextBox Text= "{Binding SelectedAxis.TargetPosition, UpdateSourceTrigger=PropertyChanged}" 
                                                     Background="Transparent" Foreground="White" BorderThickness="0" 
                                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Padding="5"/>
                                        </Border>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="▶ Move" Command="{Binding SelectedAxis.MoveAbsCommand}"
                                                Background="#10B981" BorderBrush="#10B981" Margin="0,0,4,0" Height="35" 
                                                Style="{StaticResource ModernActionButton}"/>
                                        <Button Grid.Column="1" Content="■ Stop" Command="{Binding SelectedAxis.StopCommand}"
                                                Background="#F87171" BorderBrush="#EF4444" Margin="4,0,0,0" Height="35" 
                                                Style="{StaticResource ModernActionButton}"/>
                                    </Grid>
                                </StackPanel>
                            <Separator Background="#334155" Margin="1,5"/>
                            <StackPanel>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Tag="SEL"
                                            PreviewMouseDown="JogBackward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp" Margin="0,0,4,0"
                                            Background="#334155" BorderBrush="#475569" Height="35"
                                            Style="{StaticResource ModernActionButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="◀" Margin="0,0,5,0" FontSize="10" VerticalAlignment="Center"/>
                                            <TextBlock Text="JOG -" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Tag="SEL"
                                            PreviewMouseDown="JogForward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp" Margin="4,0,0,0" 
                                            Background="#334155" BorderBrush="#475569" Height="35"
                                            Style="{StaticResource ModernActionButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="JOG +" VerticalAlignment="Center"/>
                                            <TextBlock Text="▶" Margin="5,0,0,0" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Background="#1E293B" CornerRadius="10" Padding="12" BorderBrush="#334155" BorderThickness="1" MinHeight="240">
                    <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="JOG CONTROL" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                            <!-- Jog 단위 -->
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6" HorizontalAlignment="Right">
                                <TextBlock Text="UNIT" Foreground="#64748B" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <RadioButton Content="Cont."  IsChecked="{Binding SelectedAxis.IsUnitContinuity, Mode=TwoWay}" GroupName="JogMode" Style="{StaticResource ModernModeButtonStyle}"/>
                                <RadioButton Content="10µm"   IsChecked="{Binding SelectedAxis.IsUnit10um,       Mode=TwoWay}" GroupName="JogMode" Style="{StaticResource ModernModeButtonStyle}" Margin="4,0"/>
                                <RadioButton Content="100µm"  IsChecked="{Binding SelectedAxis.IsUnit100um,      Mode=TwoWay}" GroupName="JogMode" Style="{StaticResource ModernModeButtonStyle}"/>
                            </StackPanel>
                            <!-- 속도 배율 + SEL AXIS 모드 -->
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="SPEED" Foreground="#64748B" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <RadioButton Content="×0.25" IsChecked="{Binding IsJogSpeedSlow,   Mode=TwoWay}" GroupName="JogSpeed" Style="{StaticResource ModernModeButtonStyle}"/>
                                    <RadioButton Content="×1.0"  IsChecked="{Binding IsJogSpeedNormal, Mode=TwoWay}" GroupName="JogSpeed" Style="{StaticResource ModernModeButtonStyle}" Margin="4,0"/>
                                    <RadioButton Content="×2.0"  IsChecked="{Binding IsJogSpeedFast,   Mode=TwoWay}" GroupName="JogSpeed" Style="{StaticResource ModernModeButtonStyle}"/>
                                </StackPanel>
                                <ToggleButton HorizontalAlignment="Right"
                                          IsChecked="{Binding UseSelectedAxisForJog, Mode=TwoWay}"
                                          Height="28" Padding="10,0" FontSize="10" FontWeight="SemiBold"
                                          ToolTip="ON: 조그 패드의 모든 방향이 선택 축에 명령합니다">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Content"         Value="PAD → SEL  ○"/>
                                            <Setter Property="Foreground"      Value="#94A3B8"/>
                                            <Setter Property="Background"      Value="#1F2937"/>
                                            <Setter Property="BorderBrush"     Value="#334155"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#374151"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="bd" Property="Background"      Value="#052E16"/>
                                                                <Setter TargetName="bd" Property="BorderBrush"     Value="#22C55E"/>
                                                                <Setter TargetName="bd" Property="BorderThickness" Value="1.5"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content"    Value="PAD → SEL  ●"/>
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </Grid>
                            <!-- 조그 패드 : X-Y D-패드 / Z / T  (Viewbox로 패널 너비에 맞게 스케일) -->
                        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- ── X / Y D-패드 (3×3) ── -->
                            <Border Grid.Column="0" Background="#111827" Padding="6" CornerRadius="8" Margin="0,0,8,0" BorderBrush="#1F2937" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 빈 모서리 채우기용 더미 (레이아웃 정렬) -->
                                    <Border Grid.Row="0" Grid.Column="0" Width="80" Height="62" Margin="3" Visibility="Hidden"/>
                                    <Border Grid.Row="0" Grid.Column="2" Width="80" Height="62" Margin="3" Visibility="Hidden"/>
                                    <Border Grid.Row="2" Grid.Column="0" Width="80" Height="62" Margin="3" Visibility="Hidden"/>
                                    <Border Grid.Row="2" Grid.Column="2" Width="80" Height="62" Margin="3" Visibility="Hidden"/>

                                    <!-- +Y (위) -->
                                    <Button Grid.Row="0" Grid.Column="1"
                                            Tag="Y" FontSize="15"
                                            PreviewMouseDown="JogForward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp"
                                            Style="{StaticResource JogControlStyle}"
                                            Content="↑  +Y"/>

                                    <!-- -X (왼) -->
                                    <Button Grid.Row="1" Grid.Column="0"
                                            Tag="X" FontSize="15"
                                            PreviewMouseDown="JogBackward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp"
                                            Style="{StaticResource JogControlStyle}"
                                            Content="←  -X"/>

                                    <!-- 중앙 HOME 표시 -->
                                    <Border Grid.Row="1" Grid.Column="1" Margin="3"
                                            Background="#0F172A" CornerRadius="6"
                                            BorderBrush="#334155" BorderThickness="1">
                                        <TextBlock Text="X/Y" Foreground="#475569" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- +X (오른) -->
                                    <Button Grid.Row="1" Grid.Column="2"
                                            Tag="X" FontSize="15"
                                            PreviewMouseDown="JogForward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp"
                                            Style="{StaticResource JogControlStyle}"
                                            Content="+X  →"/>

                                    <!-- -Y (아래) -->
                                    <Button Grid.Row="2" Grid.Column="1"
                                            Tag="Y" FontSize="15"
                                            PreviewMouseDown="JogBackward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp"
                                            Style="{StaticResource JogControlStyle}"
                                            Content="↓  -Y"/>
                                </Grid>
                            </Border>

                            <!-- ── Z 축 ── -->
                            <Border Grid.Column="1" Background="#111827" Padding="6" CornerRadius="8" Margin="0,0,8,0" BorderBrush="#1F2937" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Z" Foreground="#64748B" FontSize="10" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <Button Tag="Z" FontSize="15"
                                            PreviewMouseDown="JogBackward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp"
                                            Style="{StaticResource JogControlStyle}"
                                            Content="↑  -Z"/>
                                    <Button Tag="Z" FontSize="15"
                                            PreviewMouseDown="JogForward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp"
                                            Style="{StaticResource JogControlStyle}"
                                            Content="↓  +Z"/>
                                </StackPanel>
                            </Border>

                            <!-- ── T (Theta) 축 ── -->
                            <Border Grid.Column="2" Background="#111827" Padding="6" CornerRadius="8" BorderBrush="#1F2937" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="T" Foreground="#64748B" FontSize="10" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <Button Tag="T" FontSize="15"
                                            PreviewMouseDown="JogBackward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp"
                                            Style="{StaticResource JogControlStyle}"
                                            Content="↺  -T"/>
                                        <Button Tag="T" FontSize="15"
                                            PreviewMouseDown="JogForward_MouseDown"
                                            PreviewMouseUp="JogStop_MouseUp"
                                            Style="{StaticResource JogControlStyle}"
                                            Content="↻  +T"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        </Viewbox>
                    </DockPanel>
                </Border>
            </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>