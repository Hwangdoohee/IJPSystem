<UserControl x:Class="IJPSystem.Platform.HMI.Views.MotorTeachingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1150"
             Background="#0B0F1A">
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="780"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827" CornerRadius="12" Padding="15"
        BorderBrush="#334155" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="TEACHING POINT MATRIX" Foreground="#3B82F6" 
                   FontWeight="Bold" Margin="5,0,0,15"/>

                <DataGrid x:Name="PointGrid"
                          Grid.Row="1"
                          MaxHeight="650"
                          SelectedItem="{Binding SelectedTeachingPoint}"
                          PreviewMouseLeftButtonDown="PointGrid_PreviewMouseLeftButtonDown"
                          AutoGenerateColumns="False" 
                          Background="Transparent" 
                          Foreground="White"
                          BorderThickness="0" 
                          RowHeaderWidth="0" 
                          HeadersVisibility="Column"
                          RowHeight="42" 
                          ColumnHeaderHeight="42"
                          IsReadOnly="False"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#2D3748"
                          RowBackground="#111827"
                          AlternatingRowBackground="#1A2233"
                          SelectionMode="Single"
                          ColumnHeaderStyle="{StaticResource RecipeColumnHeaderStyle}"
                          HorizontalScrollBarVisibility="Visible"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalAlignment="Stretch">
                    <DataGrid.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}"/>
                    </DataGrid.Resources>
                </DataGrid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" Margin="10,0,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#1E293B" CornerRadius="12" Padding="15,12" Margin="0,0,0,15" BorderBrush="#334155" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <!-- 편집 중인 레시피 -->
                        <TextBlock Text="EDITING RECIPE" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="✏" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="16" Foreground="#3B82F6"/>
                            <TextBlock Text="{Binding EditingRecipeName}" Foreground="#93C5FD" FontSize="20" FontWeight="ExtraBold"/>
                        </StackPanel>
                        <!-- 적용된 레시피 (다를 경우 경고 색상) -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="ACTIVE : " Foreground="#64748B" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveRecipeName}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#22C55E"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecipeMismatch}" Value="True">
                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text=" ⚠ (미적용)" FontSize="11" Foreground="#F59E0B" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecipeMismatch}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="SAVE TO RECIPE" Command="{Binding SaveTeachingPointsCommand}"
                            FontSize="12" Style="{StaticResource MutedActionButtonStyle}" Width="120"
                            VerticalAlignment="Center" Height="66"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A2234" CornerRadius="12" Padding="20" 
                        BorderBrush="#3B82F6" BorderThickness="2,0,0,0" Margin="0,0,8,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ACTUAL POSITION" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding ActualPosition, StringFormat={}{0:F3}}" 
                                       Foreground="#22C55E" FontSize="42" FontWeight="ExtraBold" FontFamily="Consolas"/>
                            <TextBlock Text="mm" Foreground="#64748B" FontSize="14" Margin="8,0,0,8" VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#161E2E" CornerRadius="12" Padding="15" BorderBrush="#2D3748" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SELECT AXIS" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                                  ItemsSource="{Binding AxisList}" 
                                  SelectedItem="{Binding SelectedAxis}" 
                                  DisplayMemberPath="Info.Name" Width="170"
                                  Height="35" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                        
                        <UniformGrid Columns="2" Margin="0,15,0,0">
                            <Button Style="{StaticResource ModernAxisButtonStyle}" Margin="0,0,5,0"
                                    PreviewMouseDown="JogBackward_MouseDown" PreviewMouseUp="Jog_MouseUp">
                                <Grid HorizontalAlignment="Stretch" Width="140">
                                    <TextBlock Grid.Column="0"
                                               Text="◀"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="#94A3B8"
                                               Margin="0,0,5,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="JOG MINUS"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               FontWeight="Bold"
                                               FontSize="11"
                                               Margin="15,0,5,0"
                                               Foreground="White"/>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource ModernAxisButtonStyle}" Margin="5,0,0,0"
                                    PreviewMouseDown="JogForward_MouseDown" PreviewMouseUp="Jog_MouseUp">
                                <Grid HorizontalAlignment="Stretch" Width="140">
                                    <TextBlock Grid.Column="0"
                                               Text="JOG PLUS"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#94A3B8"
                                               Margin="8,0,5,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="▶"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="11"
                                               Foreground="White"/>
                                </Grid>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
            <Border Grid.Row="2" Background="#1E293B" CornerRadius="12" Padding="14" Margin="0,0,0,15" BorderBrush="#334155" BorderThickness="1">
                <DockPanel>

                    <!-- Header: Title + Jog Mode -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🕹️" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="14"/>
                            <TextBlock Text="XYZQ AXIS CONTROL" Foreground="#94A3B8" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <RadioButton Content="Conti." IsChecked="{Binding IsJogContinuity}" GroupName="JogMode" Style="{StaticResource ModernModeButtonStyle}"/>
                            <RadioButton Content="10µm"   IsChecked="{Binding IsUnit10um}"      GroupName="JogMode" Style="{StaticResource ModernModeButtonStyle}" Margin="6,0"/>
                            <RadioButton Content="100µm"  IsChecked="{Binding IsUnit100um}"     GroupName="JogMode" Style="{StaticResource ModernModeButtonStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Position Strip: 4 color-coded horizontal cards -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0B2818" CornerRadius="8" Padding="10,7" BorderBrush="#166534" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="X AXIS" Foreground="#22C55E" FontSize="8" FontWeight="Bold" Opacity="0.7"/>
                                <TextBlock Text="{Binding XActualPosition, StringFormat={}{0:F3}}"
                                           Foreground="#22C55E" FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                                <TextBlock Text="mm" Foreground="#22C55E" FontSize="7" Opacity="0.5" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#0C1F2E" CornerRadius="8" Padding="10,7" BorderBrush="#1D4ED8" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Y AXIS" Foreground="#38BDF8" FontSize="8" FontWeight="Bold" Opacity="0.7"/>
                                <TextBlock Text="{Binding YActualPosition, StringFormat={}{0:F3}}"
                                           Foreground="#38BDF8" FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                                <TextBlock Text="mm" Foreground="#38BDF8" FontSize="7" Opacity="0.5" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="#1C1200" CornerRadius="8" Padding="10,7" BorderBrush="#92400E" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Z AXIS" Foreground="#F59E0B" FontSize="8" FontWeight="Bold" Opacity="0.7"/>
                                <TextBlock Text="{Binding ZActualPosition, StringFormat={}{0:F3}}"
                                           Foreground="#F59E0B" FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                                <TextBlock Text="mm" Foreground="#F59E0B" FontSize="7" Opacity="0.5" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" Background="#1A0C2E" CornerRadius="8" Padding="10,7" BorderBrush="#6D28D9" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="T AXIS" Foreground="#C084FC" FontSize="8" FontWeight="Bold" Opacity="0.7"/>
                                <TextBlock Text="{Binding TActualPosition, StringFormat={}{0:F3}}"
                                           Foreground="#C084FC" FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                                <TextBlock Text="°" Foreground="#C084FC" FontSize="7" Opacity="0.5" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Z / T buttons row: 4 buttons full-width at bottom -->
                    <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Tag="Z" Width="Auto" Height="52"
                                Style="{StaticResource JogControlStyle}"
                                Background="#78350F" BorderBrush="#F59E0B"
                                PreviewMouseDown="JogForward_MouseDown" PreviewMouseUp="Jog_MouseUp">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Z" Foreground="#F59E0B" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="▲" Foreground="White" FontSize="17" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" Tag="Z" Width="Auto" Height="52"
                                Style="{StaticResource JogControlStyle}"
                                Background="#78350F" BorderBrush="#F59E0B"
                                PreviewMouseDown="JogBackward_MouseDown" PreviewMouseUp="Jog_MouseUp">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Z" Foreground="#F59E0B" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="▼" Foreground="White" FontSize="17" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" Tag="T" Width="Auto" Height="52"
                                Style="{StaticResource JogControlStyle}"
                                Background="#3B0764" BorderBrush="#C084FC"
                                PreviewMouseDown="JogBackward_MouseDown" PreviewMouseUp="Jog_MouseUp">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="T" Foreground="#C084FC" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="↺" Foreground="White" FontSize="19" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="6" Tag="T" Width="Auto" Height="52"
                                Style="{StaticResource JogControlStyle}"
                                Background="#3B0764" BorderBrush="#C084FC"
                                PreviewMouseDown="JogForward_MouseDown" PreviewMouseUp="Jog_MouseUp">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="T" Foreground="#C084FC" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="↻" Foreground="White" FontSize="19" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- XY Jog Pad: fills remaining space, centered -->
                        <Border Background="#0F172A" CornerRadius="12" Padding="8"
                            BorderBrush="#334155" BorderThickness="1">
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Row="0" Grid.Column="1"
                                    Content="▲" Tag="Y" Width="80" Height="60" FontSize="20"
                                    Style="{StaticResource JogControlStyle}"
                                    PreviewMouseDown="JogForward_MouseDown" PreviewMouseUp="Jog_MouseUp"/>
                                <Button Grid.Row="1" Grid.Column="0"
                                    Content="◀" Tag="X" Width="80" Height="60" FontSize="20"
                                    Style="{StaticResource JogControlStyle}"
                                    PreviewMouseDown="JogBackward_MouseDown" PreviewMouseUp="Jog_MouseUp"/>
                                <Border Grid.Row="1" Grid.Column="1" Width="54" Height="54"
                                    Background="#1E293B" CornerRadius="27" Margin="4">
                                    <TextBlock Text="XY" Foreground="#3B82F6" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Button Grid.Row="1" Grid.Column="2"
                                    Content="▶" Tag="X" Width="80" Height="60" FontSize="20"
                                    Style="{StaticResource JogControlStyle}"
                                    PreviewMouseDown="JogForward_MouseDown" PreviewMouseUp="Jog_MouseUp"/>
                                <Button Grid.Row="2" Grid.Column="1"
                                    Content="▼" Tag="Y" Width="80" Height="60" FontSize="20"
                                    Style="{StaticResource JogControlStyle}"
                                    PreviewMouseDown="JogBackward_MouseDown" PreviewMouseUp="Jog_MouseUp"/>
                            </Grid>
                        </Border>
                    </DockPanel>
            </Border>

            <Border Grid.Row="3" Background="#161E2E" CornerRadius="12" Padding="15" BorderBrush="#2D3748" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <Button Command="{Binding ApplyCurrentToPointCommand}" Style="{StaticResource MutedActionButtonStyle}" Height="65" Margin="0,0,12,0" Background="#2D3748">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎯" FontSize="18" Margin="0,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text="GET ACTUAL POSITION" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1" Height="65" Command="{Binding MoveToPointCommand}" Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3B82F6" CornerRadius="10" SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Margin="0,0,15,0" VerticalAlignment="Center" FontSize="22" Foreground="White"/>
                                <TextBlock Text="MOVE" FontSize="24" FontWeight="Black" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>