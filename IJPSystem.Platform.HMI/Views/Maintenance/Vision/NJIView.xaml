<UserControl x:Class="IJPSystem.Platform.HMI.Views.NJIView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cvts="clr-namespace:IJPSystem.Platform.HMI.Common.Converters"
             mc:Ignorable="d" d:DesignHeight="780" d:DesignWidth="1200"
             Background="#0B0F1A">

    <UserControl.Resources>
        <cvts:ProgressToWidthConverter     x:Key="ProgressToWidthConverter"/>
        <cvts:PathToBitmapImageConverter   x:Key="PathToBitmapImageConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측: 카메라 이미지 패널 ════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#111827" CornerRadius="12"
                BorderBrush="#334155" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Border Grid.Row="0" Background="#1E293B" CornerRadius="12,12,0,0" Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📷" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="NJI VIEW  —  CAM_01" Foreground="White"
                                   FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            <Border Margin="12,0,0,0" CornerRadius="6" Padding="8,3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#450A0A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CamStatus.IsConnected}" Value="True">
                                                <Setter Property="Background" Value="#14532D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="● DISCONNECTED"/>
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CamStatus.IsConnected}" Value="True">
                                                    <Setter Property="Text"       Value="● CONNECTED"/>
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- 이미지 열기 버튼 (우측 정렬) -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Command="{Binding OpenImageCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="저장된 이미지 파일 열기">
                            <Border CornerRadius="6" Padding="10,5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver,
                                                RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                <Setter Property="Background" Value="#475569"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📂" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="이미지 열기" Foreground="#94A3B8"
                                               FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </Grid>
                </Border>

                <!-- 이미지 영역 -->
                <Border Grid.Row="1" Background="#0D1117" Margin="2,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="99*"/>
                            <ColumnDefinition Width="75*"/>
                            <ColumnDefinition Width="514*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ① 플레이스홀더 (이미지 없을 때) -->
                        <Grid Visibility="{Binding HasNoImagePath, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.ColumnSpan="3">
                            <Line X1="0" Y1="0.5" X2="1" Y2="0.5" Stretch="Fill"
                                  Stroke="#161D2A" StrokeThickness="1"/>
                            <Line X1="0.5" Y1="0" X2="0.5" Y2="1" Stretch="Fill"
                                  Stroke="#161D2A" StrokeThickness="1"/>
                            <Border Width="260" Height="200"
                                    BorderBrush="#1E3A5F" BorderThickness="1"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect Color="#3B82F6" BlurRadius="8" Opacity="0.3" ShadowDepth="0"/>
                                </Border.Effect>
                            </Border>
                            <Canvas Width="260" Height="200"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Line Canvas.Left="0"   Canvas.Top="0"   X1="0"  Y1="0"  X2="0"  Y2="22" Stroke="#3B82F6" StrokeThickness="2"/>
                                <Line Canvas.Left="0"   Canvas.Top="0"   X1="0"  Y1="0"  X2="22" Y2="0"  Stroke="#3B82F6" StrokeThickness="2"/>
                                <Line Canvas.Left="238" Canvas.Top="0"   X1="0"  Y1="0"  X2="22" Y2="0"  Stroke="#3B82F6" StrokeThickness="2"/>
                                <Line Canvas.Left="260" Canvas.Top="0"   X1="0"  Y1="0"  X2="0"  Y2="22" Stroke="#3B82F6" StrokeThickness="2"/>
                                <Line Canvas.Left="0"   Canvas.Top="178" X1="0"  Y1="0"  X2="0"  Y2="22" Stroke="#3B82F6" StrokeThickness="2"/>
                                <Line Canvas.Left="0"   Canvas.Top="200" X1="0"  Y1="0"  X2="22" Y2="0"  Stroke="#3B82F6" StrokeThickness="2"/>
                                <Line Canvas.Left="238" Canvas.Top="200" X1="0"  Y1="0"  X2="22" Y2="0"  Stroke="#3B82F6" StrokeThickness="2"/>
                                <Line Canvas.Left="260" Canvas.Top="178" X1="0"  Y1="0"  X2="0"  Y2="22" Stroke="#3B82F6" StrokeThickness="2"/>
                            </Canvas>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="📷" FontSize="52" HorizontalAlignment="Center" Opacity="0.15"/>
                                <TextBlock Text="VIRTUAL MODE" Foreground="#1E3A5F"
                                           FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                <TextBlock Text="촬영 또는 검사 버튼을 누르세요" Foreground="#1E293B"
                                           FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- ② 캡처 이미지 (이미지 있을 때) -->
                        <Image Source="{Binding LastImagePath, Converter={StaticResource PathToBitmapImageConverter}}"
                               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                               Visibility="{Binding HasImagePath, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.ColumnSpan="3"/>

                        <!-- ③ 이미지 경로 표시 (좌상단 오버레이) -->
                        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                Background="#CC0D1117" CornerRadius="0,0,6,0" Padding="8,4"
                                Visibility="{Binding HasImagePath, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding LastImagePath}" Foreground="#64748B"
                                       FontSize="9" FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                        </Border>

                        <!-- ④ PASS / NG 결과 오버레이 (우하단) -->
                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                Margin="110,0,0,20" CornerRadius="14" Padding="36,14"
                                Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.Column="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#CC15803D"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ResultIsFail}" Value="True">
                                            <Setter Property="Background" Value="#CC991B1B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding ResultText}" Foreground="White"
                                           FontSize="36" FontWeight="Black"
                                           HorizontalAlignment="Center" FontFamily="Consolas"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <TextBlock Text="Score : " Foreground="#D1FAE5" FontSize="14"/>
                                    <TextBlock Text="{Binding ScoreText}" Foreground="White"
                                               FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="{Binding NgDescription}" Foreground="#FCA5A5"
                                           FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"
                                           Visibility="{Binding ResultIsFail, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 하단 정보 바 -->
                <Border Grid.Row="2" Background="#1E293B" CornerRadius="0,0,12,12" Padding="16,9">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="LAST CAPTURE : " Foreground="#475569"
                                   FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Text="{Binding CaptureTimeText}" Foreground="#94A3B8"
                                   FontSize="11" FontFamily="Consolas" FontWeight="Bold"/>
                        <TextBlock Text="        CAPTURE COUNT : " Foreground="#475569"
                                   FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Text="{Binding CamStatus.TotalCaptureCount}" Foreground="#94A3B8"
                                   FontSize="11" FontFamily="Consolas" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ 우측: 제어 패널 ═══════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ModernScrollBarStyle}"/>
            </ScrollViewer.Resources>

            <StackPanel>

                <!-- ── 조명 제어 ─────────────────────────────────────────── -->
                <Border Background="#111827" CornerRadius="12" Padding="16" Margin="0,0,0,10"
                        BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="LIGHT CONTROL" Foreground="#3B82F6"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                        <!-- ON / OFF 버튼 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="42"
                                    Command="{Binding LightOnCommand}"
                                    Style="{StaticResource MutedActionButtonStyle}"
                                    Background="#166534">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💡" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ON" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Height="42"
                                    Command="{Binding LightOffCommand}"
                                    Style="{StaticResource MutedActionButtonStyle}"
                                    Background="#374151">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌑" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="OFF" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- 조명 상태 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Ellipse Width="8" Height="8" Margin="0,0,7,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#374151"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CamStatus.IsLightOn}" Value="True">
                                                <Setter Property="Fill" Value="#FCD34D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="11" FontFamily="Consolas">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="LIGHT OFF"/>
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CamStatus.IsLightOn}" Value="True">
                                                <Setter Property="Text"       Value="LIGHT ON"/>
                                                <Setter Property="Foreground" Value="#FCD34D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- 강도 슬라이더 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="강도" Foreground="#64748B"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="255"
                                    Value="{Binding LightIntensity, Mode=TwoWay}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding LightIntensity}"
                                       Foreground="#FCD34D" FontSize="12" FontWeight="Bold"
                                       FontFamily="Consolas" VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── 카메라 파라미터 ────────────────────────────────────── -->
                <Border Background="#111827" CornerRadius="12" Padding="16" Margin="0,0,0,10"
                        BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="CAMERA PARAMS" Foreground="#3B82F6"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#0F172A" CornerRadius="8" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="EXPOSURE" Foreground="#475569"
                                               FontSize="9" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding CamStatus.ExposureMs, StringFormat='{}{0:F1}'}"
                                                   Foreground="White" FontSize="20" FontWeight="Bold"
                                                   FontFamily="Consolas"/>
                                        <TextBlock Text=" ms" Foreground="#64748B" FontSize="11"
                                                   VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#0F172A" CornerRadius="8" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="GAIN" Foreground="#475569"
                                               FontSize="9" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding CamStatus.Gain, StringFormat='{}{0:F1}'}"
                                                   Foreground="White" FontSize="20" FontWeight="Bold"
                                                   FontFamily="Consolas"/>
                                        <TextBlock Text=" x" Foreground="#64748B" FontSize="11"
                                                   VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── 수동 제어 버튼 ─────────────────────────────────────── -->
                <Border Background="#111827" CornerRadius="12" Padding="16" Margin="0,0,0,10"
                        BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="MANUAL CONTROL" Foreground="#3B82F6"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="58"
                                    Command="{Binding CaptureCommand}"
                                    Style="{StaticResource MutedActionButtonStyle}"
                                    Background="#1D4ED8">
                                <StackPanel>
                                    <TextBlock Text="📷" FontSize="18" HorizontalAlignment="Center"/>
                                    <TextBlock Text="CAPTURE" Foreground="White"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Height="58"
                                    Command="{Binding InspectCommand}"
                                    Style="{StaticResource MutedActionButtonStyle}"
                                    Background="#166534">
                                <StackPanel>
                                    <TextBlock Text="🔍" FontSize="18" HorizontalAlignment="Center"/>
                                    <TextBlock Text="INSPECT" Foreground="White"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- 처리 중 표시 -->
                        <Border Background="#1C1A00" CornerRadius="6" Padding="8,6" Margin="0,10,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="⏳  처리 중..." Foreground="#FCD34D"
                                       FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── 검사 결과 ──────────────────────────────────────────── -->
                <Border Background="#111827" CornerRadius="12" Padding="16" Margin="0,0,0,10"
                        BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="LAST RESULT" Foreground="#3B82F6"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                        <!-- 결과 없음 -->
                        <TextBlock Text="검사 결과 없음" Foreground="#334155"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasNoResult, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- 결과 있음 -->
                        <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border CornerRadius="10" Padding="0,16" Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#15803D"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ResultIsFail}" Value="True">
                                                <Setter Property="Background" Value="#991B1B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ResultText}" Foreground="White"
                                           FontSize="30" FontWeight="Black"
                                           HorizontalAlignment="Center" FontFamily="Consolas"/>
                            </Border>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="SCORE" Foreground="#475569" FontSize="11"/>
                                <TextBlock Text="{Binding ScoreText}" Foreground="White"
                                           FontSize="13" FontWeight="Bold"
                                           FontFamily="Consolas" HorizontalAlignment="Right"/>
                            </Grid>
                            <!-- NG 상세 -->
                            <Border Background="#1C0808" CornerRadius="8" Padding="12,10"
                                    Visibility="{Binding ResultIsFail, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding NgDescription}" Foreground="#FCA5A5"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── 통계 ──────────────────────────────────────────────── -->
                <Border Background="#111827" CornerRadius="12" Padding="16"
                        BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="STATISTICS" Foreground="#3B82F6"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                        <!-- 카운트 3칸 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#0F172A" CornerRadius="8" Padding="8,10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL" Foreground="#475569"
                                               FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalCount}" Foreground="White"
                                               FontSize="22" FontWeight="Bold" FontFamily="Consolas"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#0F172A" CornerRadius="8" Padding="8,10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="PASS" Foreground="#475569"
                                               FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PassCount}" Foreground="#22C55E"
                                               FontSize="22" FontWeight="Bold" FontFamily="Consolas"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Background="#0F172A" CornerRadius="8" Padding="8,10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="NG" Foreground="#475569"
                                               FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding NgCount}" Foreground="#EF4444"
                                               FontSize="22" FontWeight="Bold" FontFamily="Consolas"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 양품율 -->
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="양품율" Foreground="#64748B" FontSize="11"/>
                            <TextBlock Text="{Binding PassRateText}" Foreground="#3B82F6"
                                       FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="8" CornerRadius="4" Background="#1E293B" x:Name="PassRateTrack">
                            <Border HorizontalAlignment="Left" CornerRadius="4" Height="8"
                                    MinWidth="0" Background="#22C55E">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource ProgressToWidthConverter}">
                                        <Binding Path="PassRatePct"/>
                                        <Binding Path="ActualWidth" ElementName="PassRateTrack"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
