<UserControl x:Class="IJPSystem.Platform.HMI.Views.PatternPrintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="780" d:DesignWidth="1200"
             Background="#0B0F1A">

    <UserControl.Resources>
        <!-- 카드 컨테이너 -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background"      Value="#111827"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 섹션 라벨 -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 필드 라벨 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 어두운 입력 박스 -->
        <Style x:Key="DarkInputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#0D1520"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="TextAlignment"   Value="Right"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 읽기 전용 표시 박스 -->
        <Style x:Key="ReadOnlyBox" TargetType="Border">
            <Setter Property="Background"      Value="#0D1520"/>
            <Setter Property="BorderBrush"     Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="10,6"/>
        </Style>

        <Style x:Key="ReadOnlyText" TargetType="TextBlock">
            <Setter Property="Foreground"      Value="#3B82F6"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="TextAlignment"   Value="Right"/>
        </Style>

        <!-- 액션 버튼 -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측: 파라미터 입력 ════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 타이틀 + 상태 배지 -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖨" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="PATTERN GENERATOR" Foreground="White"
                                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="헤드팩 선택 · 영역(W×L) · 원점 · 인쇄 속도"
                                   Foreground="#64748B" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="8" Padding="14,8" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#475569"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOriginSet}" Value="True">
                                        <Setter Property="Background" Value="#1D4ED8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="● ORIGIN NOT SET"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOriginSet}" Value="True">
                                            <Setter Property="Text" Value="● READY"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- 파라미터 카드 -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 좌: Head Pack / nz / Using Head -->
                    <StackPanel Grid.Column="0">

                        <TextBlock Text="HEAD PACK"
                                   Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding HeadPacks}"
                                  SelectedItem="{Binding SelectedHeadPack, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch" Height="40"
                                  Background="#0D1520" Foreground="Black"
                                  BorderBrush="#1E293B" FontWeight="Bold" FontSize="16"
                                  VerticalContentAlignment="Center" Margin="0,0,0,18"/>

                        <TextBlock Text="OVERLAP (nz)"
                                   Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkInputBox}"
                                     Text="{Binding NOverlapNz, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="nz" Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="USING HEAD"
                                   Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkInputBox}"
                                     Text="{Binding UsingHead, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="ea" Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="DPI (RESOLUTION)"
                                   Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkInputBox}"
                                     Text="{Binding Dpi, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="dpi" Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                        <Border Background="#0D1520" CornerRadius="8" Padding="12,10"
                                BorderBrush="#1D4ED8" BorderThickness="1.5"
                                Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="DROP PITCH"
                                           Foreground="#64748B" FontSize="10" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DropPitchMm, StringFormat=F4}"
                                           Foreground="#475569" FontFamily="Consolas"
                                           FontSize="22" FontWeight="Black"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="mm"
                                           Foreground="#475569" FontFamily="Consolas"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 우: Width / Length -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="WIDTH"
                                   Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkInputBox}"
                                     Text="{Binding WidthMm, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="mm" Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="LENGTH"
                                   Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkInputBox}"
                                     Text="{Binding LengthMm, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="mm" Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- 영역 미리보기 박스 (가시적인 비례 표시는 단순 정보 패널) -->
                        <Border Background="#0D1520" CornerRadius="8" Padding="12"
                                BorderBrush="#1E293B" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="PRINT AREA" Foreground="#64748B"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding WidthMm, StringFormat={}{0:F1}}"
                                               Foreground="#3B82F6" FontFamily="Consolas"
                                               FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text=" × "
                                               Foreground="#475569" FontFamily="Consolas"
                                               FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LengthMm, StringFormat={}{0:F1}}"
                                               Foreground="#3B82F6" FontFamily="Consolas"
                                               FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text=" mm" Foreground="#64748B" FontFamily="Consolas"
                                               FontSize="11" VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 하단 액션 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding PrintCommand}"
                        Style="{StaticResource ActionBtn}"
                        Background="#059669" BorderBrush="#10B981"
                        Height="50" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖨" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PRINT" FontSize="15" FontWeight="Black" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Command="{Binding AbortCommand}"
                        Style="{StaticResource ActionBtn}"
                        Background="#DC2626" BorderBrush="#EF4444"
                        Height="50" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊘" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ABORT" FontSize="15" FontWeight="Black" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <!-- ══ 우측: 원점/속도/요약 ═══════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Print Origin -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="PRINT ORIGIN" Style="{StaticResource SectionLabel}"
                                   VerticalAlignment="Center"/>
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="10" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="Text" Value="NOT SET"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOriginSet}" Value="True">
                                            <Setter Property="Foreground" Value="#22C55E"/>
                                            <Setter Property="Text" Value="● CAPTURED"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyBox}">
                            <TextBlock Style="{StaticResource ReadOnlyText}"
                                       Text="{Binding XOrigin, StringFormat={}{0:F3} mm}"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Y" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyBox}">
                            <TextBlock Style="{StaticResource ReadOnlyText}"
                                       Text="{Binding YOrigin, StringFormat={}{0:F3} mm}"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Z" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyBox}">
                            <TextBlock Style="{StaticResource ReadOnlyText}"
                                       Text="{Binding ZOrigin, StringFormat={}{0:F3} mm}"/>
                        </Border>
                    </Grid>

                    <Button Command="{Binding SetPrintOriginCommand}"
                            Style="{StaticResource ActionBtn}"
                            Background="#1D4ED8" BorderBrush="#3B82F6"
                            Height="40">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◎" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="SET PRINT ORIGIN" FontSize="12"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Print Velocity -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="PRINT VELOCITY" Style="{StaticResource SectionLabel}"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding PrintVelocity, StringFormat={}{0:F2}}"
                                   Foreground="#3B82F6" FontFamily="Consolas"
                                   FontSize="28" FontWeight="Black" VerticalAlignment="Center"/>
                        <TextBlock Text="mm/s" Foreground="#475569" FontFamily="Consolas"
                                   FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Bottom" Margin="6,0,0,8"/>
                    </StackPanel>
                    <TextBlock Text="* 활성 레시피의 X축 Print 속도"
                               Foreground="#475569" FontSize="9" FontStyle="Italic"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Summary -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel>
                    <TextBlock Text="SUMMARY" Style="{StaticResource SectionLabel}"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Head Pack" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding SelectedHeadPack}"
                                   Foreground="White" FontFamily="Consolas" FontSize="11"
                                   FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Overlap" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Foreground="White" FontFamily="Consolas" FontSize="11"
                                   FontWeight="Bold" HorizontalAlignment="Right"
                                   Text="{Binding NOverlapNz, StringFormat={}{0} nz}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Using Head" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Foreground="White" FontFamily="Consolas" FontSize="11"
                                   FontWeight="Bold" HorizontalAlignment="Right"
                                   Text="{Binding UsingHead, StringFormat={}{0} ea}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Width × Length" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Foreground="White" FontFamily="Consolas" FontSize="11"
                                       FontWeight="Bold"
                                       Text="{Binding WidthMm, StringFormat={}{0:F2}}"/>
                            <TextBlock Foreground="#475569" Text=" × " FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Foreground="White" FontFamily="Consolas" FontSize="11"
                                       FontWeight="Bold"
                                       Text="{Binding LengthMm, StringFormat={}{0:F2} mm}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="DPI" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Foreground="White" FontFamily="Consolas" FontSize="11"
                                       FontWeight="Bold"
                                       Text="{Binding Dpi, StringFormat={}{0} dpi}"/>
                            <TextBlock Foreground="#475569" Text=" / " FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Foreground="#3B82F6" FontFamily="Consolas" FontSize="11"
                                       FontWeight="Bold"
                                       Text="{Binding DropPitchMm, StringFormat={}{0:F4} mm}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
