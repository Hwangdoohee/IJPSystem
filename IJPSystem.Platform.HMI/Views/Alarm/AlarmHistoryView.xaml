<UserControl x:Class="IJPSystem.Platform.HMI.Views.AlarmHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IJPSystem.Platform.HMI.Views"
             xmlns:viewmodels="clr-namespace:IJPSystem.Platform.HMI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#0F172A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 타이틀 행 -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#EF4444" Width="4" Height="24" CornerRadius="2" Margin="0,0,15,0"/>
                    <TextBlock Text="{DynamicResource Title_AlarmHistory}" Foreground="White" FontSize="22" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Total Active:" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding AlarmVM.ActiveAlarmCount}" Foreground="#EF4444" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- 검색 바 -->
            <Border Grid.Row="2" Background="#1E293B" CornerRadius="10" Padding="14,10"
                    BorderBrush="#334155" BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Text="FROM" Foreground="#94A3B8" FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding AlarmVM.FilterStartDate, Mode=TwoWay}"
                                Width="130" Height="32" FontSize="13" FontWeight="Bold"
                                Background="#0F172A" Foreground="Black"
                                BorderBrush="#475569" SelectedDateFormat="Short"
                                VerticalContentAlignment="Center"/>

                    <TextBlock Text="TO" Foreground="#94A3B8" FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="12,0,8,0"/>
                    <DatePicker SelectedDate="{Binding AlarmVM.FilterEndDate, Mode=TwoWay}"
                                Width="130" Height="32" FontSize="13" FontWeight="Bold"
                                Background="#0F172A" Foreground="Black"
                                BorderBrush="#475569" SelectedDateFormat="Short"
                                VerticalContentAlignment="Center"/>

                    <Border Background="#0F172A" BorderBrush="#475569" BorderThickness="1"
                            CornerRadius="6" Height="32" Margin="16,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="#64748B" FontSize="13"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBox Text="{Binding AlarmVM.FilterKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="White" FontSize="13"
                                     BorderThickness="0" VerticalContentAlignment="Center"
                                     Width="200" Padding="4,0" CaretBrush="White">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding AlarmVM.SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <Button Content="SEARCH" Command="{Binding AlarmVM.SearchCommand}"
                            Width="90" Height="32" Margin="12,0,0,0"
                            Style="{StaticResource ModernActionButton}"
                            Background="#1D4ED8" BorderBrush="#3B82F6"/>
                    <Button Content="RESET" Command="{Binding AlarmVM.ResetFilterCommand}"
                            Width="80" Height="32" Margin="8,0,0,0"
                            Style="{StaticResource ModernActionButton}"
                            Background="#334155" BorderBrush="#475569"/>

                    <TextBlock Foreground="#64748B" FontSize="11" FontStyle="Italic"
                               VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}Showing: {0} records">
                                <Binding Path="AlarmVM.FilteredAlarmHistory.Count" FallbackValue="0"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="#1E293B" CornerRadius="12" Padding="5" BorderBrush="#334155" BorderThickness="1">
            <DataGrid x:Name="AlarmDataGrid"
                      ItemsSource="{Binding AlarmVM.FilteredAlarmHistory}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#334155"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeight="48"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      ColumnHeaderStyle="{StaticResource CommonColumnHeaderStyle}"
                      CellStyle="{StaticResource CommonCellStyle}"
                      MouseLeftButtonUp="AlarmRow_MouseLeftButtonUp">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="START TIME" 
                            Binding="{Binding OccurredTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" 
                            Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="END TIME" 
                            Binding="{Binding ResolvedTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}, TargetNullValue='-'}" 
                            Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="CODE" 
                            Binding="{Binding AlarmCode}" 
                            Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FCD34D"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="ALARM NAME" 
                            Binding="{Binding AlarmName}" Width="1.5*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SEVERITY"
                            Binding="{Binding Severity}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Severity}" Value="Fatal">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="Error">
                                        <Setter Property="Foreground" Value="#F97316"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                        <Setter Property="Foreground" Value="#EAB308"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="Info">
                                        <Setter Property="Foreground" Value="#3B82F6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="REPEAT" Width="70"
                            Binding="{Binding RepeatCount, StringFormat=×{0}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#FB923C"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RepeatCount}" Value="1">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="STATUS" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,4" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="85">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#991B1B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCleared}" Value="True">
                                                    <Setter Property="Background" Value="#065F46"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock FontSize="10" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="● ACTIVE"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCleared}" Value="True">
                                                        <Setter Property="Text" Value="✓ CLEARED"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACK" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="ACK"
                                        Command="{Binding DataContext.AlarmVM.AckSingleAlarmCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Width="64" Height="28">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ModernActionButton}">
                                            <Setter Property="Background" Value="#059669"/>
                                            <Setter Property="BorderBrush" Value="#10B981"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCleared}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Background" Value="#1E293B"/>
                                                    <Setter Property="BorderBrush" Value="#334155"/>
                                                    <Setter Property="Foreground" Value="#475569"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="EXPORT CSV" Click="ExportButton_Click" 
                                Width="130" Height="38" 
                                Style="{StaticResource ModernActionButton}" Background="#334155" BorderBrush="#475569"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="ALARM RESET" 
                                Command="{Binding AlarmVM.ClearAlarmCommand}"
                                Width="110" Height="38" Margin="0,0,10,0"
                                Style="{StaticResource ModernActionButton}" 
                                Background="#059669" BorderBrush="#10B981"/>
                <Button Content="ALARM CLEAR" 
                                Command="{Binding AlarmVM.DeleteHistoryCommand}" 
                                Width="110" Height="38" Margin="0,0,10,0"
                                Style="{StaticResource ModernActionButton}" 
                                Background="#3B82F6" BorderBrush="#60A5FA"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>