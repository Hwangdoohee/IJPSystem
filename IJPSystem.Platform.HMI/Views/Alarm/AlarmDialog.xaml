<Window x:Class="IJPSystem.Platform.HMI.Views.AlarmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Alarm" Height="400" Width="640" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" Topmost="True">

    <Border x:Name="MainBorder" Background="#1E293B" CornerRadius="12" BorderThickness="3">
        <Border.BorderBrush>
            <SolidColorBrush x:Name="BorderBrushTarget" Color="#EF4444"/>
        </Border.BorderBrush>

        <Border.Effect>
            <DropShadowEffect x:Name="GlowEffect" BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="#EF4444"/>
        </Border.Effect>

        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <ColorAnimation Storyboard.TargetName="BorderBrushTarget"
                                        Storyboard.TargetProperty="Color"
                                        From="#EF4444" To="#334155" 
                                        Duration="0:0:0.6" AutoReverse="True"/>
                        <DoubleAnimation Storyboard.TargetName="GlowEffect" 
                                         Storyboard.TargetProperty="Opacity"
                                         From="0.2" To="0.8" 
                                         Duration="0:0:0.8" AutoReverse="True"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="65"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="85"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="10,10,0,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop x:Name="HeaderStop1" Color="#DC2626" Offset="0"/>
                        <GradientStop x:Name="HeaderStop2" Color="#991B1B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="SirenIcon" Text="🚨" FontSize="24" Margin="0,0,15,0">
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.3" Duration="0:0:0.4"
                                                             AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                        <TextBlock x:Name="HeaderTitle" Text="SYSTEM ALARM" Foreground="White" FontWeight="Black" FontSize="20" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border x:Name="AlarmCodeBadge" Background="#450A0A" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="10,4" CornerRadius="4">
                        <TextBlock x:Name="AlarmCodeText" Text="{Binding AlarmCode}" Foreground="#FCA5A5" FontSize="14" FontWeight="Bold" FontFamily="Consolas"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="30,25">
                <StackPanel>
                    <TextBlock Text="{Binding AlarmMessage}" Foreground="White" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="30"/>
                    <Border Background="#0F172A" CornerRadius="10" Padding="20" BorderBrush="#334155" BorderThickness="1.5">
                        <StackPanel>
                            <TextBlock Text="■ ACTION GUIDE" Foreground="#60A5FA" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding ActionGuide}" Foreground="#E2E8F0" FontSize="15" TextWrapping="Wrap" LineHeight="24"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="#111827" CornerRadius="0,0,10,10" BorderBrush="#1E293B" BorderThickness="0,1,0,0">
                <Grid Margin="25,0">
                    <!--<TextBlock Text="Contact Support: +82-10-XXXX-XXXX" Foreground="#475569" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>-->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="ACK" Click="ACK_Click" Width="130" Height="50" Margin="0,0,15,0"
                                FontSize="16" FontWeight="Bold" Foreground="White"
                                Style="{StaticResource ModernActionButton}" Background="#334155" BorderBrush="#475569"/>
                        <Button Content="RESET" Click="Reset_Click" Width="130" Height="50"
                                FontSize="16" FontWeight="Bold" Foreground="White"
                                Style="{StaticResource ModernActionButton}" Background="#991B1B" BorderBrush="#B91C1C"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>