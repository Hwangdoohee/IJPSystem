<Window x:Class="IJPSystem.Platform.HMI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IJPSystem.Platform.HMI"
        xmlns:viewmodels="clr-namespace:IJPSystem.Platform.HMI.ViewModels"
        xmlns:views="clr-namespace:IJPSystem.Platform.HMI.Views"
        mc:Ignorable="d" WindowState="Maximized" Title="IJP System v1.0" Background="#0F172A"
        Closing="MainWindow_Closing">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:MainDashboardViewModel}">
            <views:MainDashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SequenceViewModel}">
            <views:SequenceView />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,0,2">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="White" Width="42" Height="42" CornerRadius="8" Padding="5">
                        <Image Source="/Images/logo.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center" Margin="15,0,20,0">
                        <TextBlock Text="GOSAN TECH" Foreground="#3B82F6" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding DisplayMachineName}" Foreground="White" FontSize="20" FontWeight="ExtraBold"/>
                    </StackPanel>

                    <Border Background="#0F172A" CornerRadius="12" Padding="10,4" BorderBrush="#3B82F6" BorderThickness="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Foreground="#60A5FA" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding UserStatusText}" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Content="LOGOUT" Command="{Binding LogoutCommand}" 
                            Visibility="{Binding IsEngineerMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource ModernActionButton}" Background="#C0392B" 
                            Width="60" Height="22" Margin="8,0,0,0" FontSize="8"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="{Binding SystemTime}" Foreground="#FCD34D" FontSize="16" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Right"/>
                        <TextBlock Text="SYSTEM TIME" Foreground="#94A3B8" FontSize="8" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Border Width="110" Height="34" Background="#0F172A" CornerRadius="17" BorderBrush="#334155" BorderThickness="1.5">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="16" Height="16" Margin="4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#450a0a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasActiveAlarm}" Value="True">
                                                <Setter Property="Fill" Value="#EF4444"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="BlinkRed">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.4" AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="BlinkRed"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="16" Height="16" Margin="4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#451a03"/>
                                        <Setter Property="Opacity" Value="0.3"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasActiveAlarm}" Value="False"/>
                                                    <Condition Binding="{Binding IsStandby}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Fill" Value="#F59E0B"/>
                                                <Setter Property="Opacity" Value="1.0"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="16" Height="16" Margin="4,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#064e3b"/>
                                        <Setter Property="Opacity" Value="0.3"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasActiveAlarm}" Value="False"/>
                                                    <Condition Binding="{Binding IsRunning}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Fill" Value="#22C55E"/>
                                                <Setter Property="Opacity" Value="1.0"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Vertical" 
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center" 
                                Margin="20">
                        <Button Command="{Binding ToggleLanguageCommand}"
                                Width="60" Height="30"
                                Style="{StaticResource ModernActionButton}" 
                                Background="#334155"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="12" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding CurrentLanguage}" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        
        <Border Grid.Row="1" Grid.Column="0" Background="#F1F5F9" CornerRadius="12" Margin="15,15,5,15">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
        
        <Border Grid.Row="1" Grid.Column="1" Background="#1E293B" CornerRadius="12" Margin="5,15,15,15">
            <StackPanel Margin="10">
                <TextBlock Text="SUB MENU" Foreground="#94A3B8"
                           FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,15"/>
                <!-- ── MAIN 메뉴 선택 시에만 표시 ── -->
                <Button Content="{DynamicResource SubMenu_AutoPrint}"
                        Style="{StaticResource MainSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="AUTO_PRINT"/>
                <Button Content="{DynamicResource SubMenu_Initialize}"
                        Style="{StaticResource MainSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="INITIALIZE"/>
                <!-- 일반 서브메뉴 버튼 -->
                <Button Content="{DynamicResource SubMenu_IO}"
                        Style="{StaticResource MaintenanceSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="IO"/>
                <Button Content="{DynamicResource SubMenu_Motor}"
                        Style="{StaticResource MaintenanceSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="MOTOR"/>
                <!-- MOTOR 하위 메뉴 -->
                <StackPanel Visibility="{Binding IsMotorSubMenuVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="{DynamicResource SubMenu_AxisControl}"
                            Style="{StaticResource SubNavButtonStyle}"
                            Command="{Binding MoveWindowCommand}" CommandParameter="AXIS_CONTROL"/>
                    <Button Content="{DynamicResource SubMenu_PositionTeach}"
                            Style="{StaticResource SubNavButtonStyle}"
                            Command="{Binding MoveWindowCommand}" CommandParameter="POSITION_TEACH"/>
                </StackPanel>
                <Button Content="{DynamicResource SubMenu_VISION}"
                        Style="{StaticResource MaintenanceSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="VISION"/>
                <StackPanel Visibility="{Binding IsVisionSubMenuVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="{DynamicResource SubMenu_NJI}"
                            Style="{StaticResource SubNavButtonStyle}"
                            Command="{Binding MoveWindowCommand}" CommandParameter="NJI"/>
                    <Button Content="{DynamicResource SubMenu_GLASS_VIEW}"
                            Style="{StaticResource SubNavButtonStyle}"
                            Command="{Binding MoveWindowCommand}" CommandParameter="GLASS_VIEW"/>
                    <Button Content="{DynamicResource SubMenu_DROP_WATCHER}"
                            Style="{StaticResource SubNavButtonStyle}"
                            Command="{Binding MoveWindowCommand}" CommandParameter="DROP_WATCHER"/>
                    
                </StackPanel>
                <Button Content="{DynamicResource SubMenu_PNID}"
                        Style="{StaticResource MaintenanceSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="PNID"/>
                <Button Content="{DynamicResource SubMenu_Sequence}"
                        Style="{StaticResource MaintenanceSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="SEQUENCE"/>
                <!-- ── PRINT 서브메뉴 ── -->
                <Button Content="{DynamicResource SubMenu_PatternPrint}"
                        Style="{StaticResource PrintSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="PATTERN_PRINT"/>
                <Button Content="{DynamicResource SubMenu_Waveform}"
                        Style="{StaticResource PrintSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="WAVEFORM"/>
                
                <!-- ── RECIPE 메뉴 선택 시에만 표시 ── -->
                <Button Content="{DynamicResource SubMenu_MotorInfo}"
                        Style="{StaticResource RecipeSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="MOTOR_INFO"/>

                <Button Content="{DynamicResource SubMenu_TeachingPoint}"
                        Style="{StaticResource RecipeSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="TEACH_INFO"/>
                
                <Button Content="{DynamicResource SubMenu_OtherPoint}"
                        Style="{StaticResource RecipeSubButtonStyle}"
                        Command="{Binding MoveWindowCommand}" CommandParameter="OTHER_INFO"/>
                <Separator Background="#334155" Margin="10,15"/>
                <Button Content="{DynamicResource SubMenu_SystemExit}"
                        Command="{Binding ExitCommand}"
                        Background="#C0392B"
                        Style="{StaticResource ModernMenuButton}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                Background="#0F172A" Margin="15,0,15,10" 
                CornerRadius="12" BorderBrush="#1E293B" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer x:Name="LogScrollViewer" Grid.Column="0"
                      VerticalScrollBarVisibility="Auto" 
                      Padding="15,2,5,2" 
                      ScrollChanged="LogScrollViewer_ScrollChanged">
                    <ItemsControl ItemsSource="{Binding SystemLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <TextBlock Text="{Binding Time, StringFormat='[{0:HH:mm:ss}]'}" Foreground="#64748B" FontSize="11" Margin="0,0,8,0" FontFamily="Consolas"/>
                                    <TextBlock Text="{Binding Level, StringFormat='[{0}]'}" Foreground="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}" FontSize="11" FontWeight="Bold" Width="65" Margin="0,0,5,0" FontFamily="Consolas"/>
                                    <TextBlock Text="{Binding Message}" Foreground="#E2E8F0" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Column="1" 
                        Command="{Binding ClearLogCommand}" 
                        Background="Transparent" 
                        BorderThickness="0" Cursor="Hand" 
                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,12,0"
                        ToolTip="All Log DEL">
                    <StackPanel Orientation="Horizontal" Opacity="0.6">
                        <TextBlock Text="🗑" Foreground="#64748B" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="CLEAR" Foreground="#64748B" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1.0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
        <Border Grid.Row="3" Grid.ColumnSpan="2" Background="#0F172A" BorderBrush="#334155" BorderThickness="0,1,0,0">
            <Grid Margin="30,0,30,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <RadioButton Content="{DynamicResource Menu_Main}"
                         GroupName="MainMenu"
                         Style="{StaticResource NavMenuButtonStyle}"
                         CommandParameter="MAIN"
                         IsChecked="{Binding SelectedMenu, Mode=TwoWay, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=MAIN}"/>
                    <RadioButton Content="{DynamicResource Menu_Print}"
                         GroupName="MainMenu"
                         Style="{StaticResource NavMenuButtonStyle}"
                         CommandParameter="PRINT"
                         IsChecked="{Binding SelectedMenu, Mode=TwoWay, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=PRINT}"/>
                    <RadioButton Content="{DynamicResource Menu_Maintenance}"
                         GroupName="MainMenu"
                         Style="{StaticResource NavMenuButtonStyle}"
                         CommandParameter="MAINTENANCE"
                         IsChecked="{Binding SelectedMenu, Mode=TwoWay, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=MAINTENANCE}"/>
                    <RadioButton Content="{DynamicResource Menu_Recipe}"
                         GroupName="MainMenu"
                         CommandParameter="RECIPE"
                         IsChecked="{Binding SelectedMenu, Mode=TwoWay, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=RECIPE}">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton" BasedOn="{StaticResource NavMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentUserRole}" Value="Operator">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity" Value="0.3"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                    <RadioButton Content="{DynamicResource Menu_AlarmHistory}"  
                         GroupName="MainMenu"
                         CommandParameter="ALARM" 
                         Style="{StaticResource NavMenuButtonStyle}"
                         IsChecked="{Binding SelectedMenu, Mode=TwoWay, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=ALARM}"/>
                </StackPanel>
                <Button Content="{DynamicResource Menu_LogView}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource NavMenuLogButtonStyle}" 
                        Command="{Binding OpenLogWindowCommand}"
                        Margin="0,0,10,0"/>
            </Grid>
        </Border>
        <StatusBar Grid.Row="4" Grid.ColumnSpan="2" Background="#1E293B" BorderThickness="0,1,0,0" BorderBrush="#334155">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- Col 0: 머신 상태 -->
            <StatusBarItem Grid.Column="0" Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#64748B"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStandby}"     Value="True"><Setter Property="Fill" Value="#F59E0B"/></DataTrigger>
                                    <DataTrigger Binding="{Binding IsRunning}"     Value="True"><Setter Property="Fill" Value="#22C55E"/></DataTrigger>
                                    <DataTrigger Binding="{Binding HasActiveAlarm}" Value="True"><Setter Property="Fill" Value="#EF4444"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding MachineStatusText}" FontSize="11" FontWeight="Bold" FontFamily="Consolas">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStandby}"     Value="True"><Setter Property="Foreground" Value="#F59E0B"/></DataTrigger>
                                    <DataTrigger Binding="{Binding IsRunning}"     Value="True"><Setter Property="Foreground" Value="#22C55E"/></DataTrigger>
                                    <DataTrigger Binding="{Binding HasActiveAlarm}" Value="True"><Setter Property="Foreground" Value="#EF4444"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>

            <Separator Grid.Column="1" Background="#334155" Width="1" Margin="5,8"/>

            <!-- Col 2: 드라이버 연결 상태 -->
            <StatusBarItem Grid.Column="2" Margin="10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- IO -->
                    <Ellipse Width="7" Height="7" Margin="0,0,3,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#EF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IOConnected}" Value="True">
                                        <Setter Property="Fill" Value="#22C55E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="IO" Foreground="#94A3B8" FontSize="10" FontFamily="Consolas" Margin="0,0,8,0"/>
                    <!-- MOTION -->
                    <Ellipse Width="7" Height="7" Margin="0,0,3,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#EF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MotionConnected}" Value="True">
                                        <Setter Property="Fill" Value="#22C55E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="MOTION" Foreground="#94A3B8" FontSize="10" FontFamily="Consolas" Margin="0,0,8,0"/>
                    <!-- VISION -->
                    <Ellipse Width="7" Height="7" Margin="0,0,3,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#EF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding VisionConnected}" Value="True">
                                        <Setter Property="Fill" Value="#22C55E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="VISION" Foreground="#94A3B8" FontSize="10" FontFamily="Consolas"/>
                </StackPanel>
            </StatusBarItem>

            <Separator Grid.Column="3" Background="#334155" Width="1" Margin="5,8"/>

            <!-- Col 4: 마지막 로그 메시지 -->
            <StatusBarItem Grid.Column="4" HorizontalContentAlignment="Stretch">
                <TextBlock Text="{Binding LastLogMessage}"
                           Foreground="#64748B" Margin="15,0"
                           FontSize="11" FontStyle="Italic"
                           TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>

            <!-- Col 5: 알람 카운트 + RECIPE -->
            <StatusBarItem Grid.Column="5" Margin="15,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- 알람 뱃지 (활성 알람 있을 때만 표시) -->
                    <Border Background="#EF4444" CornerRadius="8" Padding="6,1" Margin="0,0,12,0"
                            Visibility="{Binding HasActiveAlarm, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ ALARM " Foreground="White" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="{Binding AlarmVM.ActiveAlarmCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="RECIPE :  " Foreground="#94A3B8" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding RecipeVM.ActiveRecipeName}"
                               Foreground="#3B82F6" FontSize="12" FontWeight="Bold"
                               Margin="0,0,20,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>