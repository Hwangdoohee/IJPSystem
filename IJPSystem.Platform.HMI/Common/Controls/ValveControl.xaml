<UserControl x:Class="IJPSystem.Platform.HMI.Common.Controls.ValveControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <Border Background="#1A1A2E" CornerRadius="4" Padding="8" Margin="2">
        <StackPanel HorizontalAlignment="Center">
            <!-- 밸브 심볼 (보타이) -->
            <Grid Width="40" Height="24" HorizontalAlignment="Center">
                <Path Stroke="#7FFFFFFF" StrokeThickness="1.5"
                      Fill="{Binding ElementName=root, Path=IsOpen,
                             Converter={StaticResource BoolToValveBrush}}"
                      Data="M 4,4 L 36,20 L 36,4 L 4,20 Z"/>
            </Grid>
            <TextBlock Text="{Binding ElementName=root, Path=Label}"
                       FontSize="10" Foreground="#9090B0"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <TextBlock Text="{Binding ElementName=root, Path=IsOpen,
                              Converter={StaticResource BoolToOnOff}}"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{Binding ElementName=root, Path=IsOpen,
                                    Converter={StaticResource BoolToValveBrush}}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
