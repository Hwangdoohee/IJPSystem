<UserControl x:Class="IJPSystem.Platform.HMI.Common.Controls.DrainBottle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <!-- DrainBottle: 납작한 병 모양 + 받침대.
         envelope 110×80, body 내부 y=13~80. 받침대 y=80~92 (좌측 -8 ~ 우측 118).
         우측에 3 센서, 좌측에 tag -->
    <Canvas>
        <!-- 받침대 (containment tray) -->
        <Rectangle Canvas.Left="-8" Canvas.Top="80" Width="126" Height="12"
                   Stroke="#475569" StrokeThickness="1.5" Fill="#1A1707"
                   RadiusX="2" RadiusY="2"/>
        <Line X1="-6" Y1="83" X2="116" Y2="83"
              Stroke="#FCD34D" StrokeThickness="0.5" Opacity="0.4"/>

        <!-- 병 실루엣 (cap + neck + 어깨 + body) -->
        <Path Stroke="#EAB308" StrokeThickness="2" Fill="#1E293B"
              Data="M 46,0 L 64,0 L 64,3 L 62,3 L 62,10 L 110,13 L 110,80 L 0,80 L 0,13 L 48,10 L 48,3 L 46,3 Z"/>

        <!-- Liquid (body 내부) -->
        <Rectangle x:Name="Liquid" Canvas.Left="3" Canvas.Top="76" Width="104" Height="4"
                   Fill="#713F12" Opacity="0.6"/>
        <Line x:Name="LevelLine" X1="3" X2="107" Y1="76" Y2="76"
              Stroke="#FBBF24" StrokeThickness="1" StrokeDashArray="4,3"/>

        <!-- 어깨 하이라이트 -->
        <Line X1="3" Y1="14" X2="48" Y2="11" Stroke="#FCD34D" StrokeThickness="0.5" Opacity="0.3"/>
        <Line X1="62" Y1="11" X2="107" Y2="14" Stroke="#FCD34D" StrokeThickness="0.5" Opacity="0.3"/>

        <!-- ── 3 Sensors (우측 외부) ── -->
        <!-- HIGH (액위 상한, 본체 상단) -->
        <Ellipse Canvas.Left="118" Canvas.Top="18" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorHigh, Converter={StaticResource BoolToSensorBrush}}"/>
        <TextBlock Canvas.Left="125" Canvas.Top="6" Text="HIGH" Foreground="#64748B" FontSize="8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <!-- DETECT (보틀 감지, 받침대 위) -->
        <Ellipse Canvas.Left="118" Canvas.Top="48" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorDetect, Converter={StaticResource BoolToSensorBrush}}"/>
        <TextBlock Canvas.Left="125" Canvas.Top="36" Text="DETC" Foreground="#64748B" FontSize="8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <!-- LEAK (받침대 영역, 누액 감지 — 알람) -->
        <Ellipse Canvas.Left="118" Canvas.Top="82" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorLeak, Converter={StaticResource BoolToSensorBrush}, ConverterParameter=Alarm}"/>
        <TextBlock Canvas.Left="125" Canvas.Top="81" Text="LEAK" Foreground="#64748B" FontSize="8" HorizontalAlignment="Left" VerticalAlignment="Center"/>

        <!-- Tag (body 좌측 외부) -->
        <Border Canvas.Left="-39" Canvas.Top="40"
                Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="2" Padding="4,1"
                HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Text="{Binding ElementName=root, Path=TagId}"
                       Foreground="#FBBF24" FontSize="11" FontFamily="Consolas" FontWeight="Bold"/>
        </Border>
        <!-- Caption (받침대 아래) -->
        <TextBlock Canvas.Left="3" Canvas.Top="100"
                   Text="{Binding ElementName=root, Path=Caption}"
                   Foreground="#94A3B8" FontSize="9" FontWeight="Bold"/>
    </Canvas>
</UserControl>
