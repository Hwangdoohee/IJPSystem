<UserControl x:Class="IJPSystem.Platform.HMI.Common.Controls.PurgeBath"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <!-- PurgeBath: 가로 520×50, anchor=좌상단 (8헤드 전체 커버) -->
    <Canvas>
        <Rectangle Canvas.Left="0" Canvas.Top="0" Width="520" Height="50"
                   Stroke="#EAB308" StrokeThickness="2" Fill="#1E293B" RadiusX="2" RadiusY="2"/>
        <Rectangle x:Name="Liquid" Canvas.Left="3" Width="514" Fill="#713F12" Opacity="0.5"/>
        <Line x:Name="LevelLine" X1="3" X2="517" Stroke="#FCD34D" StrokeThickness="1" StrokeDashArray="4,3"/>
        <!-- Tag (body 안쪽 상단 중앙, body width 520 기준) -->
        <Border Canvas.Left="240" Canvas.Top="14"
                Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="2" Padding="4,1">
            <TextBlock Text="{Binding ElementName=root, Path=TagId}"
                       Foreground="#FBBF24" FontSize="10" FontFamily="Consolas" FontWeight="Bold"/>
        </Border>
        <TextBlock Canvas.Left="225" Canvas.Top="32"
                   Text="{Binding ElementName=root, Path=Caption}"
                   Foreground="#94A3B8" FontSize="9"/>
    </Canvas>
</UserControl>
