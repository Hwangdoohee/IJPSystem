<UserControl x:Class="IJPSystem.Platform.HMI.Common.Controls.PMC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <Canvas>
        <!-- Body -->
        <Rectangle Canvas.Left="0" Canvas.Top="0" Width="284" Height="106"
                   Stroke="#A855F7" StrokeThickness="2" Fill="#1E293B" RadiusX="6" RadiusY="6" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Canvas.Left="15" Canvas.Top="8" Padding="10,4" Text="PMC" Foreground="White" FontSize="16" FontWeight="Bold"/>
            <TextBlock Grid.Column="1" Canvas.Left="15" Canvas.Top="29" Padding="4,12" Text="Pressure Meniscus Controller" Foreground="White" FontSize="9"/>
        </Grid>
        <!-- ── 양압 (P+) section : 좌측 ── -->
        <Border Canvas.Left="10" Canvas.Top="29" Width="130" Height="72"
                Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="3" Padding="6,4" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="P+(Purge/양압)"
                           Foreground="#FB923C" FontSize="9" FontWeight="Bold" FontFamily="Consolas"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="kPa"
                           Foreground="#64748B" FontSize="8" FontFamily="Consolas"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <!-- PV row -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="PV"
                           Foreground="#94A3B8" FontSize="9" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding ElementName=root, Path=PressurePV, StringFormat=F2}"
                           Foreground="#FBBF24" FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>

                <!-- SV row + SET button -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="SV"
                           Foreground="#94A3B8" FontSize="9" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBox  Grid.Row="2" Grid.Column="1"
                          Text="{Binding ElementName=root, Path=PressureSV, StringFormat=F2, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                          Foreground="White" Background="Transparent"
                          BorderThickness="0,0,0,1" BorderBrush="#475569"
                          FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                          HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                          Padding="0,0,4,0" Margin="0"/>
                <Button Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" Content="SET"
                        Command="{Binding ElementName=root, Path=SetPressureCommand}"
                        Background="#1E40AF" Foreground="White"
                        FontSize="9" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Margin="2,2,0,2"/>
            </Grid>
        </Border>

        <!-- ── 음압 (P-) section : 우측 ── -->
        <Border Canvas.Left="145" Canvas.Top="29" Width="130" Height="72"
                Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="3" Padding="6,4" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="P-(Meniscus/음압)"
                           Foreground="#C084FC" FontSize="9" FontWeight="Bold" FontFamily="Consolas"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="kPa"
                           Foreground="#64748B" FontSize="8" FontFamily="Consolas"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="PV"
                           Foreground="#94A3B8" FontSize="9" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding ElementName=root, Path=VacuumPV, StringFormat=F2}"
                           Foreground="#FBBF24" FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="SV"
                           Foreground="#94A3B8" FontSize="9" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBox  Grid.Row="2" Grid.Column="1"
                          Text="{Binding ElementName=root, Path=VacuumSV, StringFormat=F2, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                          Foreground="White" Background="Transparent"
                          BorderThickness="0,0,0,1" BorderBrush="#475569"
                          FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                          HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                          Padding="0,0,4,0" Margin="0"/>
                <Button Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" Content="SET"
                        Command="{Binding ElementName=root, Path=SetVacuumCommand}"
                        Background="#1E40AF" Foreground="White"
                        FontSize="9" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Margin="2,2,0,2"/>
            </Grid>
        </Border>
    </Canvas>
</UserControl>
