<UserControl x:Class="IJPSystem.Platform.HMI.Common.Controls.Reservoir"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <!-- Reservoir: body 520×120, anchor=(0,0). 우측에 4점 센서, 상단 P+/P- 인입 -->
    <Canvas>
        <!-- Body -->
        <Rectangle Canvas.Left="0" Canvas.Top="0" Width="520" Height="120"
                   Stroke="#3B82F6" StrokeThickness="2" Fill="#1E293B" RadiusX="3" RadiusY="3"/>
        <!-- Liquid (초기값: 가시성 위해 Empty 수준 7px) -->
        <Rectangle x:Name="Liquid" Canvas.Left="4" Canvas.Top="113" Width="512" Height="7"
                   Fill="#1E3A5F" Opacity="0.85"/>
        <Line x:Name="LevelLine" X1="4" X2="516" Y1="113" Y2="113"
              Stroke="#60A5FA" StrokeThickness="1" StrokeDashArray="4,3"/>
        <!-- 4-point sensors (우측 외부) -->
        <Ellipse Canvas.Left="528" Canvas.Top="15" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorHH, Converter={StaticResource BoolToSensorBrush}, ConverterParameter=Alarm}"/>
        <TextBlock Canvas.Left="540" Canvas.Top="12" Text="HH" Foreground="#64748B" FontSize="8"/>
        <Ellipse Canvas.Left="528" Canvas.Top="35" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorHigh, Converter={StaticResource BoolToSensorBrush}}"/>
        <TextBlock Canvas.Left="540" Canvas.Top="32" Text="H" Foreground="#64748B" FontSize="8"/>
        <Ellipse Canvas.Left="528" Canvas.Top="65" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorSet, Converter={StaticResource BoolToSensorBrush}}"/>
        <TextBlock Canvas.Left="540" Canvas.Top="62" Text="S" Foreground="#64748B" FontSize="8"/>
        <Ellipse Canvas.Left="528" Canvas.Top="105" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorEmpty, Converter={StaticResource BoolToSensorBrush}, ConverterParameter=Inverted}"/>
        <TextBlock Canvas.Left="540" Canvas.Top="102" Text="E" Foreground="#64748B" FontSize="8"/>
        <!-- 상단 P+/P- 인입 포트 (위로 돌출) — PMC 파이프 도달점 (canvas x=380, 410)에 맞춤 -->
        <Ellipse Canvas.Left="173" Canvas.Top="-5" Width="14" Height="14"
                 Stroke="#F97316" StrokeThickness="1.5" Fill="#1E293B"/>
        <Ellipse Canvas.Left="203" Canvas.Top="-5" Width="14" Height="14"
                 Stroke="#A855F7" StrokeThickness="1.5" Fill="#1E293B"/>
        <!-- Tag + caption (body 중앙 영역) -->
        <Border Canvas.Left="240" Canvas.Top="60"
                Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="2" Padding="4,1">
            <TextBlock Text="{Binding ElementName=root, Path=TagId}"
                       Foreground="#60A5FA" FontSize="11" FontFamily="Consolas" FontWeight="Bold"/>
        </Border>
        <TextBlock Canvas.Left="245" Canvas.Top="80" Text="RESERVOIR" Foreground="#94A3B8" FontSize="11" FontWeight="Bold"/>
        <TextBlock Canvas.Left="255" Canvas.Top="96"
                   Text="{Binding ElementName=root, Path=Caption}"
                   Foreground="#475569" FontSize="9"/>
    </Canvas>
</UserControl>
