<UserControl x:Class="IJPSystem.Platform.HMI.Common.Controls.Canister"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <!-- Canister: 병 모양 (cap + neck + 어깨 + body) + 받침대.
         bottle envelope 90×160, body 내부 y=22~160. 받침대 y=160~174 (좌측 -8 ~ 우측 98).
         x<0 = 좌측 센서 영역, y<0 = P+ 인입 포트 -->
    <Canvas>
        <!-- 받침대 (containment tray, 본체보다 약간 넓음) -->
        <Rectangle Canvas.Left="-8" Canvas.Top="160" Width="106" Height="14"
                   Stroke="#475569" StrokeThickness="1.5" Fill="#0F1A2C"
                   RadiusX="2" RadiusY="2"/>
        <Line X1="-6" Y1="163" X2="96" Y2="163"
              Stroke="#94A3B8" StrokeThickness="0.5" Opacity="0.4"/>

        <!-- 병 실루엣 (cap + neck + body 한 path) -->
        <Path Stroke="#3B82F6" StrokeThickness="2" Fill="#1E293B"
              Data="M 27,0 L 63,0 L 63,4 L 60,4 L 60,18 L 90,22 L 90,160 L 0,160 L 0,22 L 30,18 L 30,4 L 27,4 Z"/>

        <!-- Liquid (body 내부) -->
        <Rectangle x:Name="Liquid" Canvas.Left="3" Canvas.Top="151" Width="84" Height="9"
                   Fill="#1E3A5F" Opacity="0.85"/>
        <Line x:Name="LevelLine" X1="3" X2="87" Y1="151" Y2="151"
              Stroke="#60A5FA" StrokeThickness="1" StrokeDashArray="4,3"/>

        <!-- 어깨 하이라이트 (입체감) -->
        <Line X1="3" Y1="24" X2="30" Y2="20" Stroke="#60A5FA" StrokeThickness="0.6" Opacity="0.4"/>
        <Line X1="60" Y1="20" X2="87" Y2="24" Stroke="#60A5FA" StrokeThickness="0.6" Opacity="0.4"/>

        <!-- P+ inlet port (cap 위) -->
        <Ellipse Canvas.Left="38" Canvas.Top="-9" Width="14" Height="14"
                 Stroke="#F97316" StrokeThickness="1.5" Fill="#1E293B"/>

        <!-- ── 3 Sensors (좌측 외부) ── -->
        <!-- HIGH (액위 상한, 본체 상단) -->
        <Ellipse Canvas.Left="-20" Canvas.Top="30" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorHigh, Converter={StaticResource BoolToSensorBrush}}"/>
        <TextBlock Canvas.Left="-40" Canvas.Top="27" Text="HIGH" Foreground="#64748B" FontSize="8"/>
        <!-- DETECT (보틀 감지, 받침대 위) -->
        <Ellipse Canvas.Left="-20" Canvas.Top="130" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorDetect, Converter={StaticResource BoolToSensorBrush}}"/>
        <TextBlock Canvas.Left="-44" Canvas.Top="127" Text="DETC" Foreground="#64748B" FontSize="8"/>
        <!-- LEAK (받침대 영역, 누액 감지 — 알람) -->
        <Ellipse Canvas.Left="-20" Canvas.Top="164" Width="8" Height="8"
                 Fill="{Binding ElementName=root, Path=SensorLeak, Converter={StaticResource BoolToSensorBrush}, ConverterParameter=Alarm}"/>
        <TextBlock Canvas.Left="-40" Canvas.Top="161" Text="LEAK" Foreground="#64748B" FontSize="8"/>

        <!-- Tag + caption (받침대 아래) -->
        <Border Canvas.Left="0" Canvas.Top="182"
                Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="2" Padding="4,1">
            <TextBlock Text="{Binding ElementName=root, Path=TagId}"
                       Foreground="#60A5FA" FontSize="10" FontFamily="Consolas" FontWeight="Bold"/>
        </Border>
        <TextBlock Canvas.Left="5" Canvas.Top="200" Text="CANISTER" Foreground="#94A3B8" FontSize="10" FontWeight="Bold"/>
        <TextBlock Canvas.Left="3" Canvas.Top="214"
                   Text="{Binding ElementName=root, Path=Caption}"
                   Foreground="#475569" FontSize="9"/>
    </Canvas>
</UserControl>
