<UserControl x:Class="IJPSystem.Platform.HMI.Common.Controls.InstrumentBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <!-- 계장 버블 (PT/FI/PI/LT 등). anchor=원의 중심점 부근, 26×42 -->
    <Canvas>
        <!-- 원 -->
        <Ellipse Canvas.Left="0" Canvas.Top="14" Width="26" Height="26"
                 Stroke="#64748B" StrokeThickness="1.5" Fill="#1E293B"/>
        <!-- 타입 (2글자, 원 안쪽) -->
        <TextBlock Canvas.Left="6" Canvas.Top="20"
                   Text="{Binding ElementName=root, Path=Type}"
                   Foreground="#64748B" FontSize="9" FontWeight="Bold"
                   FontFamily="Consolas"/>
        <!-- 태그 (원 위쪽) -->
        <TextBlock Canvas.Left="-4" Canvas.Top="0"
                   Text="{Binding ElementName=root, Path=TagId}"
                   Foreground="#475569" FontSize="8" FontFamily="Consolas"/>
    </Canvas>
</UserControl>
