<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:cvts="clr-namespace:IJPSystem.Platform.HMI.Common.Converters">

    <!-- ═══════════════════════════════════════
         CONVERTERS
    ═══════════════════════════════════════ -->
    <cvts:BooleanToVisibilityConverter      x:Key="BooleanToVisibilityConverter"/>
    <cvts:SignalToColorConverter            x:Key="SignalToColorConverter"/>
    <cvts:SignalToColorConverter            x:Key="BoolToColorConverter"/>
    <cvts:SignalToTextConverter             x:Key="SignalToTextConverter"/>
    <cvts:AlarmToColorConverter             x:Key="AlarmToColorConverter"/>
    <cvts:SensorToBgConverter              x:Key="SensorToBgConverter"/>
    <cvts:LogLevelToColorConverter          x:Key="LogLevelToColorConverter"/>
    <cvts:StringToBooleanConverter          x:Key="StringToBooleanConverter"/>
    <cvts:ConnectionToTextConverter         x:Key="ConnectionToTextConverter"/>
    <cvts:IntToVisibilityConverter          x:Key="IntToVisibilityConverter"/>
    <cvts:IntToInverseVisibilityConverter   x:Key="IntToInverseVisibilityConverter"/>
    <!-- 서브메뉴 선택 상태 판별: SelectedSubMenu == CommandParameter -->
    <cvts:IsSelectedConverter               x:Key="IsSelectedConverter"/>

    <!-- P&ID — 탱크/밸브/센서 컨버터 -->
    <cvts:LevelStatusToBrushConverter       x:Key="LevelStatusToBrush"/>
    <cvts:LevelStatusToHeightConverter      x:Key="LevelStatusToHeight"/>
    <cvts:ValveStateToBrushConverter        x:Key="ValveStateToBrush"/>
    <cvts:BoolToValveBrushConverter         x:Key="BoolToValveBrush"/>
    <cvts:BoolToOnOffConverter              x:Key="BoolToOnOff"/>
    <cvts:BoolToSensorBrushConverter        x:Key="BoolToSensorBrush"/>
    <cvts:SensorBrushMultiConverter         x:Key="SensorBrushMulti"/>


    <!-- ═══════════════════════════════════════
         BUTTON STYLES
    ═══════════════════════════════════════ -->

    <!-- 기본 버튼 (모든 버튼의 베이스) -->
    <Style x:Key="ModernMenuButton" TargetType="Button">
        <Setter Property="Height"      Value="50"/>
        <Setter Property="Margin"      Value="8,4"/>
        <Setter Property="Foreground"  Value="White"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────
         서브메뉴 버튼 (기본 숨김 + 선택 시 파란 하이라이트)
         - SubMenuButtonStyle : 공통 베이스 (Collapsed + active 하이라이트 트리거)
         - 메뉴별 파생       : SelectedMenu 일치 시 Visibility=Visible 트리거 추가
         - active 하이라이트 : SelectedSubMenu == CommandParameter 일 때 파란색
    ───────────────────────────────────────────────────────── -->
    <Style x:Key="SubMenuButtonStyle" TargetType="Button"
           BasedOn="{StaticResource ModernMenuButton}">
        <Setter Property="Background" Value="#475569"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Style.Triggers>
            <DataTrigger Value="True">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource IsSelectedConverter}">
                        <Binding Path="SelectedSubMenu"/>
                        <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Background" Value="#1D4ED8"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="White"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MainSubButtonStyle" TargetType="Button"
           BasedOn="{StaticResource SubMenuButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding SelectedMenu}" Value="MAIN">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MaintenanceSubButtonStyle" TargetType="Button"
           BasedOn="{StaticResource SubMenuButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding SelectedMenu}" Value="MAINTENANCE">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PrintSubButtonStyle" TargetType="Button"
           BasedOn="{StaticResource SubMenuButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding SelectedMenu}" Value="PRINT">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RecipeSubButtonStyle" TargetType="Button"
           BasedOn="{StaticResource SubMenuButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding SelectedMenu}" Value="RECIPE">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ─────────────────────────────────────────────────────────
         들여쓰기 하위 버튼 (AXIS CONTROL, POSITION TEACH 등)
         active 하이라이트 동일 패턴 내장 — 별도 *ActiveStyle 불필요
    ───────────────────────────────────────────────────────── -->
    <Style x:Key="SubNavButtonStyle" TargetType="Button">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="#94A3B8"/>
        <Setter Property="Height"                     Value="32"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Margin"                     Value="15,2,10,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter VerticalAlignment="Center" Margin="10,0"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Value="True">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource IsSelectedConverter}">
                        <Binding Path="SelectedSubMenu"/>
                        <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Background" Value="#1D4ED8"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="White"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <Style x:Key="EditableCellStyle" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1E3A5F"/>
                <Setter Property="BorderBrush" Value="#3B82F6"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Trigger>
            <Trigger Property="IsEditing" Value="True">
                <Setter Property="Background" Value="#1E3A5F"/>
                <Setter Property="BorderBrush" Value="#60A5FA"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <!-- 액션 버튼 (소형 버튼, LOGOUT 등) -->
    <Style x:Key="ModernActionButton" TargetType="Button">
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#334155"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 조그 컨트롤 버튼 -->
    <Style x:Key="JogControlStyle" TargetType="Button"
           BasedOn="{StaticResource ModernActionButton}">
        <Setter Property="Width"        Value="80"/>
        <Setter Property="Height"       Value="62"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Background"   Value="#1D4ED8"/>
        <Setter Property="BorderBrush"  Value="#3B82F6"/>
        <Setter Property="Margin"       Value="3"/>
    </Style>
    
    <Style x:Key="MutedActionButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="#1E293B" CornerRadius="10" BorderBrush="#334155" BorderThickness="1.5">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#334155"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- 메인 대시보드 버튼 -->
    <Style x:Key="MainDashboardButtonStyle" TargetType="Button">
        <Setter Property="Height"      Value="50"/>
        <Setter Property="Width"       Value="140"/>
        <Setter Property="Foreground"  Value="White"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background" Value="#0F172A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════
         NAVIGATION (RadioButton / Log Button)
    ═══════════════════════════════════════ -->

    <!-- 하단 메인 메뉴 (MAIN / MAINTENANCE / RECIPE / ALARM) -->
    <Style x:Key="NavMenuButtonStyle" TargetType="RadioButton">
        <Setter Property="Height"      Value="75"/>
        <Setter Property="Width"       Value="160"/>
        <Setter Property="Margin"      Value="10,0,0,0"/>
        <Setter Property="Foreground"  Value="#64748B"/>
        <Setter Property="FontSize"    Value="15"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Command"     Value="{Binding MoveWindowCommand}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="MainBorder" 
                            Background="Transparent" 
                            BorderBrush="Transparent" 
                            BorderThickness="0,4,0,0">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#2D3748"/>
                            <Setter Property="Foreground" Value="#93C5FD"/>
                            <Setter Property="Cursor"     Value="Hand"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="MainBorder" Property="Background"   Value="#1D4ED8"/>
                            <Setter TargetName="MainBorder" Property="BorderBrush"  Value="#60A5FA"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LOG VIEW 버튼 -->
    <Style x:Key="NavMenuLogButtonStyle" TargetType="Button">
        <Setter Property="Height"          Value="75"/>
        <Setter Property="Width"           Value="160"/>
        <Setter Property="Margin"          Value="10,0,0,0"/>
        <Setter Property="Foreground"      Value="#64748B"/>
        <Setter Property="FontSize"        Value="15"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="MainBorder" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="Transparent" 
                            BorderThickness="0,4,0,0">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#2D3748"/>
                            <Setter Property="Foreground" Value="#93C5FD"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#1D4ED8"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 탭 형태 RadioButton (세로 내비게이션) -->
    <Style x:Key="NavTabButtonStyle" TargetType="RadioButton">
        <Setter Property="Height"     Value="55"/>
        <Setter Property="Foreground" Value="#64748B"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="4,0,0,0"
                            Cursor="Hand">
                        <ContentPresenter HorizontalAlignment="Left" 
                                          VerticalAlignment="Center" 
                                          Margin="20,0">
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize"   Value="14"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                            <Setter TargetName="Border" Property="Background"  Value="#1E293B"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#2D3748"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 서브 메뉴 RadioButton -->
    <Style x:Key="NavMenuSubButtonStyle" TargetType="RadioButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="MainBorder" 
                            Background="Transparent" 
                            BorderBrush="Transparent" 
                            BorderThickness="4,0,0,0">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="MainBorder" Property="Background"  Value="#1E293B"/>
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3B82F6"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 모드 선택 RadioButton (소형, 체크 시 파란 테두리 + 글로우) -->
    <Style x:Key="ModernModeButtonStyle" TargetType="RadioButton">
        <Setter Property="Height"          Value="28"/>
        <Setter Property="Width"           Value="65"/>
        <Setter Property="Foreground"      Value="#94A3B8"/>
        <Setter Property="Background"      Value="#1F2937"/>
        <Setter Property="BorderBrush"     Value="#334155"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#374151"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="border" Property="Background"        Value="#1E293B"/>
                            <Setter TargetName="border" Property="BorderBrush"       Value="#3B82F6"/>
                            <Setter TargetName="border" Property="BorderThickness"   Value="1.5"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="8" Color="#3B82F6" 
                                                      Opacity="0.4" ShadowDepth="0"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════
         DATAGRID STYLES
    ═══════════════════════════════════════ -->

    <Style x:Key="CommonDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns"    Value="False"/>
        <Setter Property="IsReadOnly"             Value="True"/>
        <Setter Property="Background"             Value="Transparent"/>
        <Setter Property="BorderThickness"        Value="0"/>
        <Setter Property="GridLinesVisibility"    Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#1E293B"/>
        <Setter Property="HeadersVisibility"      Value="Column"/>
        <Setter Property="RowHeight"              Value="35"/>
        <Setter Property="RowBackground"          Value="Transparent"/>
        <Setter Property="Foreground"             Value="#CBD5E1"/>
    </Style>

    <!-- 기본 컬럼 헤더 (키 없는 전역 Style) -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"              Value="#1E293B"/>
        <Setter Property="Foreground"              Value="#94A3B8"/>
        <Setter Property="FontWeight"              Value="Bold"/>
        <Setter Property="Padding"                 Value="10,8"/>
        <Setter Property="FontSize"                Value="11"/>
        <Setter Property="BorderThickness"         Value="0,0,1,1"/>
        <Setter Property="BorderBrush"             Value="#334155"/>
    </Style>

    <!-- 공통 컬럼 헤더 (키 있음, 명시적 적용용) -->
    <Style x:Key="CommonColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background"              Value="#1E293B"/>
        <Setter Property="Foreground"              Value="#94A3B8"/>
        <Setter Property="Padding"                 Value="15,12"/>
        <Setter Property="FontWeight"              Value="SemiBold"/>
        <Setter Property="FontSize"                Value="12"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderThickness"         Value="0,0,0,1"/>
        <Setter Property="BorderBrush"             Value="#334155"/>
    </Style>

    <!-- 공통 셀 Style -->
    <Style x:Key="CommonCellStyle" TargetType="DataGridCell">
        <Setter Property="Foreground"              Value="White"/>
        <Setter Property="Background"              Value="Transparent"/>
        <Setter Property="BorderThickness"         Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center" Margin="15,0"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#3B82F6"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 비교 셀 Style (우정렬, Dirty 상태 표시) -->
    <Style x:Key="CompareCellStyle" TargetType="DataGridCell">
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Padding"                    Value="0,0,15,0"/>
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="White"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, 
                                           Path=DataContext.IsDirty}" 
                         Value="True">
                <Setter Property="BorderBrush"     Value="#F59E0B"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </DataTrigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="IsEditing" Value="True"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AxisNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#334155"/>
        <Setter Property="Foreground" Value="#3B82F6"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Width" Value="70"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#475569" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#475569"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernAxisButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="Foreground" Value="#60A5FA"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="#334155" 
                        BorderThickness="1" 
                        CornerRadius="6">
                        <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#2D3A4F"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            <Setter Property="Foreground" Value="#93C5FD"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#0F172A"/>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="RecipeCompareCellStyle" TargetType="DataGridCell"
       BasedOn="{StaticResource CompareCellStyle}">
        <Setter Property="FontSize"                   Value="15"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
    </Style>
    
    <Style x:Key="RecipeColumnHeaderStyle" TargetType="DataGridColumnHeader"
       BasedOn="{StaticResource CommonColumnHeaderStyle}">
        <Setter Property="FontSize"  Value="15"/>
        <Setter Property="Height"    Value="45"/>
    </Style>

    <Style x:Key="RecipeSaveButtonStyle" TargetType="Button" 
       BasedOn="{StaticResource MainDashboardButtonStyle}">
        <Setter Property="Background" Value="#334155"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsDirty}" Value="True">
                <Setter Property="Background"  Value="#F59E0B"/>
                <Setter Property="BorderBrush" Value="White"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Width" Value="180"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#334155"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Style.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1F2937" />
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1D4ED8" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
        </Style.Resources>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="#1F2937"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="8,4"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3B82F6"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="TeachingDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource CommonDataGridStyle}">
        <Setter Property="IsReadOnly" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>

        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>

        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="TeachingNumericCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource RecipeCompareCellStyle}">
        
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="BorderBrush" Value="#3B82F6"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 기본 행 Style (전역) -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin"          Value="0,2"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2D3748"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="JogButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#1F2937"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#334155"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

        <!-- 눌림 애니메이션 준비 -->
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="MainBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">

                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#374151"/>
                        </Trigger>

                        <!-- Press (핵심) -->
                        <Trigger Property="IsPressed" Value="True">
                            <!-- 색상 -->
                            <Setter TargetName="MainBorder" Property="Background" Value="#2563EB"/>
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3B82F6"/>

                            <!-- 눌리는 느낌 -->
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!-- 비활성 -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="MainBorder" Property="Opacity" Value="0.4"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         TAB STYLES
    ═══════════════════════════════════════ -->

    <!-- TabItem 전역 Style (언더라인 형태) -->
    <Style TargetType="TabItem">
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid x:Name="Root" Margin="0,0,10,0">
                        <Border x:Name="TabBorder" Padding="15,8">
                            <ContentPresenter ContentSource="Header" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="Underline" Height="2" 
                                Background="Transparent" 
                                VerticalAlignment="Bottom"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Underline" Property="Background" Value="#3B82F6"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════
         SCROLLBAR STYLE
    ═══════════════════════════════════════ -->

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
        <Setter Property="Stylus.IsFlicksEnabled"       Value="false"/>
        <Setter Property="Width"                        Value="8"/>
        <Setter Property="Background"                   Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid x:Name="Bg" SnapsToDevicePixels="true">
                        <Border Background="#1E293B" CornerRadius="4"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Style>
                                        <Style TargetType="{x:Type Thumb}">
                                            <Setter Property="OverridesDefaultStyle" Value="true"/>
                                            <Setter Property="IsTabStop"             Value="false"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                        <Border x:Name="rectangle"
                                                                Background="#475569"
                                                                CornerRadius="4"
                                                                Height="{TemplateBinding Height}"
                                                                Width="{TemplateBinding Width}"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                <Setter TargetName="rectangle" Property="Background" Value="#64748B"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="true">
                                                                <Setter TargetName="rectangle" Property="Background" Value="#3B82F6"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Thumb.Style>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 수직 스크롤바 -->
    <Style x:Key="ModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
        <Setter Property="Stylus.IsFlicksEnabled"       Value="false"/>
        <Setter Property="Width"                        Value="8"/>
        <Setter Property="MinWidth"                     Value="8"/>
        <Setter Property="Background"                   Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid x:Name="Bg" SnapsToDevicePixels="true">
                        <Border Background="#1E293B" CornerRadius="4"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" IsTabStop="false"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Style>
                                        <Style TargetType="{x:Type Thumb}">
                                            <Setter Property="OverridesDefaultStyle" Value="true"/>
                                            <Setter Property="IsTabStop"             Value="false"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                        <Border x:Name="rectangle"
                                                            Background="#475569"
                                                            CornerRadius="4"
                                                            Height="{TemplateBinding Height}"
                                                            Width="{TemplateBinding Width}"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                <Setter TargetName="rectangle" Property="Background" Value="#64748B"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="true">
                                                                <Setter TargetName="rectangle" Property="Background" Value="#3B82F6"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Thumb.Style>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" IsTabStop="false"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        
        <!-- ✅ 수평일 때 자동 전환 -->
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width"   Value="Auto"/>
                <Setter Property="Height"  Value="8"/>
                <Setter Property="MinHeight" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                <Border Background="#1E293B" CornerRadius="4"/>
                                <Track x:Name="PART_Track" IsDirectionReversed="false">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineLeftCommand" Opacity="0" IsTabStop="false"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Style>
                                                <Style TargetType="{x:Type Thumb}">
                                                    <Setter Property="OverridesDefaultStyle" Value="true"/>
                                                    <Setter Property="IsTabStop"             Value="false"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                                <Border x:Name="rectangle"
                                                                    Background="#475569"
                                                                    CornerRadius="4"
                                                                    Height="{TemplateBinding Height}"
                                                                    Width="{TemplateBinding Width}"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="true">
                                                                        <Setter TargetName="rectangle" Property="Background" Value="#64748B"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsDragging" Value="true">
                                                                        <Setter TargetName="rectangle" Property="Background" Value="#3B82F6"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Thumb.Style>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineRightCommand" Opacity="0" IsTabStop="false"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════
         CARD / TEXT STYLES
    ═══════════════════════════════════════ -->

    <Style x:Key="StatusCardStyle" TargetType="Border">
        <Setter Property="Background"       Value="#1E293B"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="20"/>
        <Setter Property="Margin"           Value="0,0,0,15"/>
        <Setter Property="BorderBrush"      Value="#334155"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsError}" Value="True">
                <Setter Property="Background"  Value="#451A1A"/>
                <Setter Property="BorderBrush" Value="#EF4444"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="#94A3B8"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Margin"      Value="0,0,0,12"/>
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="#94A3B8"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="Bold"/>
    </Style>

    <!-- ═══════════════════════════════════════
         P&ID
    ═══════════════════════════════════════ -->
   
</ResourceDictionary>